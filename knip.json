{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "apps/*": {
      "entry": ["src/index.ts", "src/main.ts", "src/index.tsx", "src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
