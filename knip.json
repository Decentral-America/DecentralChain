{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  // Exclude unused exports/types from the report: SDK packages have zero unused exports (verified),
  // and app workspaces (exchange, scanner) are in active development — many components and features
  // are being built ahead of routing and will be wired in as dev continues.
  // Unused files and unused dependencies are still tracked.
  "exclude": ["exports", "types"],
  "ignore": [
    // exchange: ambient module-augmentation declaration files — not imported, but required for type inference
    "apps/exchange/src/styles/styled.d.ts",
    "apps/exchange/src/types/charting_library.d.ts",
    // monitor-ci: standalone CLI scripts executed by GitHub Actions / AI agents (not imported by JS modules)
    ".agents/skills/monitor-ci/scripts/**",
    ".github/skills/monitor-ci/scripts/**",
    ".opencode/skills/monitor-ci/scripts/**",
    // NX generators: invoked by NX CLI, not imported
    "tools/generators/**"
  ],
  "ignoreDependencies": [
    "undici-types",
    "@bufbuild/protoc-gen-es",
    // cubensis-connect: browser polyfills referenced via vite.config.ts aliases/plugins
    "buffer",
    "events",
    "stream-browserify",
    "util",
    // cubensis-connect: babel plugins referenced as string names in vite.config.ts babel config
    "@babel/core",
    "babel-plugin-prismjs",
    // cubensis-connect: CSS @import in global.css — not visible to knip static analysis
    "normalize.css",
    // cubensis-connect: ambient WebUSB global types needed by @ledgerhq/hw-transport-webusb
    "@types/w3c-web-usb",
    // cubensis-connect: mocha-style globals used in e2e tests via webdriverio
    "@types/mocha",
    // scanner: used in vitest.config.ts + postcss.config.js / CSS @import
    "@vitejs/plugin-react",
    "tailwindcss",
    "tw-animate-css",
    // exchange: used in advanced transaction forms and wallet features not yet wired into routing
    "@hookform/resolvers",
    "zod",
    // exchange: data-service layer (lib/data-service/**) is build-ahead — fully implemented but not yet
    // wired to routing/pages. These deps are actively used there and will be production deps once connected.
    "@decentralchain/assets-pairs-order",
    "@decentralchain/browser-bus",
    "@decentralchain/data-entities",
    "@decentralchain/data-service-client-js",
    "@decentralchain/oracle-data",
    // used only in data-service layer which is excluded from TS compilation
    "bignumber.js",
    "ramda",
    "ts-utils",
    // exchange: TradingView charting library is a proprietary binary distribution — not on npm
    "charting_library",
    // sdk-package: local NX generator (not an npm package)
    "sdk-package"
    // Note: esbuild is now tracked via vitest.base.config.ts root entry — removed from ignore
  ],
  "vitest": {
    "config": []
  },
  "workspaces": {
    ".": {
      // vitest.base.config.ts is the shared Vitest base config imported by all package vitest.config.ts files.
      // This entry is required so knip can trace the vitest/config and vite/esbuild imports.
      "entry": ["vitest.base.config.ts"]
    },
    "apps/cubensis-connect": {
      "entry": [
        "src/popup.tsx",
        "src/popupRoot.tsx",
        "src/accounts.tsx",
        "src/accountsRoot.tsx",
        "src/background.ts",
        "src/contentscript.ts",
        "src/inpage.ts",
        "src/constants.ts",
        "test/*.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "test/**/*.{ts,tsx}"]
    },
    "apps/data-service": {
      "entry": [
        "src/index.ts",
        "src/daemons/pairs/index.ts",
        "src/daemons/presets/daemon.ts",
        "tsdown.config.ts",
        "vitest.config.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "apps/exchange": {
      // True app entry: main.tsx bootstraps tokenFilters + formatters + logger + i18n + App.
      // App.tsx pulls in styles, contexts, and the router which lazy-loads all pages.
      // pages/**/*.tsx is kept as secondary entry so knip can trace each page directly.
      "entry": ["src/main.tsx", "src/pages/**/*.tsx", "test/setup.ts"],
      "ignore": [
        // ── DATA-SERVICE LAYER ────────────────────────────────────────────────
        // Excluded from TypeScript compilation (tsconfig.app.json `exclude`).
        // Accessed at runtime only via the Vite path alias:
        //   data-service → src/lib/data-service
        // TypeScript resolves `import … from 'data-service'` to src/types/data-service.d.ts.
        // Never import src/lib/data-service files directly — use the module alias.
        "src/lib/data-service/**",

        // ── BLOCKED ON DCC-178 (backend deployment) ───────────────────────────
        // These modules call api.decentralchain.io which is not yet live.
        // Wire once DCC-178 (infra deployment) is complete.
        "src/api/**",                               // REST client layer (axios + auth interceptors)
        "src/lib/api.ts",                           // low-level fetch wrapper consumed by api/
        "src/services/api/**",                      // service factories wrapping the REST client
        "src/services/auth/**",                     // auth API (login, refresh, logout)
        "src/services/gateways/**",                 // exchange gateway integrations (DCC, SEPA)
        "src/services/index.ts",                    // services barrel (aggregates above)
        "src/services/storage/**",                  // encrypted remote-storage service
        "src/services/websocket/**",                // WebSocket client for price/order feeds
        "src/features/dex/useDexWebSocket.ts",      // DEX WS hook (depends on websocket/)
        "src/features/dex/useMarketData.ts",        // DEX market-data hook (depends on api/)

        // ── BUILD-AHEAD: UI features not yet wired to routing ─────────────────
        // Fully implemented but no page or component imports them yet.
        // Wire in subsequent sprints as the routing layer expands.
        "src/features/advanced/**",                 // advanced tx forms: alias, mass-transfer, set-script, data-tx
        "src/features/assets/**",                   // token management: issue, burn, reissue, asset-info
        "src/features/auth/AccountSelectScreen.tsx",// account-selection screen shown after password entry
        "src/features/auth/AccountSwitcher.tsx",    // quick account-switch widget (header/sidebar)
        "src/features/auth/index.ts",               // features/auth barrel (re-export only)
        "src/features/auth/PasswordProtection.tsx", // encrypt-seed-with-password step in onboarding
        "src/features/dex/index.ts",                // features/dex barrel (re-export only)
        "src/features/sessions/**",                 // session context: auto-lock, cross-tab sync
        "src/features/settings/index.ts",           // features/settings barrel (re-export only)
        "src/features/wallet/AssetInfoModal.tsx",   // asset detail drawer
        "src/features/wallet/BurnAssetModal.tsx",   // burn-token action modal
        "src/features/wallet/DepositAssetModal.tsx",// deposit-asset modal
        "src/features/wallet/ReissueAssetModal.tsx",// reissue-token modal
        "src/features/wallet/SepaAssetModal.tsx",   // SEPA fiat on-ramp modal

        // ── BUILD-AHEAD: UI component library ────────────────────────────────
        // Atoms, organisms, display, and chart components built ahead of the pages
        // that will consume them. Add imports as pages are fleshed out.
        "src/components/AssetName.tsx",
        "src/components/Breadcrumbs.tsx",
        "src/components/EmptyState.tsx",
        "src/components/LazyImage.tsx",
        "src/components/RouteLoadingFallback.tsx",
        "src/components/VirtualList.tsx",
        "src/components/atoms/Avatar.tsx",
        "src/components/atoms/Box.tsx",
        "src/components/atoms/Divider.tsx",
        "src/components/atoms/GlassCard.tsx",
        "src/components/atoms/Grid.tsx",
        "src/components/atoms/index.ts",
        "src/components/atoms/Radio.tsx",
        "src/components/atoms/Tooltip.tsx",
        "src/components/charts/**",
        "src/components/data/index.ts",
        "src/components/display/**",
        "src/components/forms/**",
        "src/components/index.ts",
        "src/components/landing/TestimonialsStrip.tsx",
        "src/components/layout/Header.tsx",         // alternative header (MainLayout has its own built-in)
        "src/components/layout/Sidebar.tsx",        // alternative sidebar (MainLayout has its own built-in)
        "src/components/layout/index.ts",
        "src/components/modals/AlertModal.tsx",
        "src/components/modals/index.ts",
        "src/components/modals/LedgerConnectModal.tsx",
        "src/components/modals/LedgerErrorModal.tsx",
        "src/components/modals/LedgerSignModal.tsx",
        "src/components/modals/NoAccountModal.tsx",
        "src/components/notifications/index.ts",
        "src/components/organisms/index.ts",
        "src/components/organisms/LanguageSwitcher.tsx",
        "src/components/skeletons/**",
        "src/components/ui/**",
        "src/components/wallet/**",

        // ── BUILD-AHEAD: React hooks ──────────────────────────────────────────
        // Implemented and tested; awaiting the feature pages that consume them.
        "src/hooks/useAssetName.ts",
        "src/hooks/useAuthEvents.ts",
        "src/hooks/useExplorerLinks.ts",
        "src/hooks/useMediaStream.ts",
        "src/hooks/useMultiAccount.ts",
        "src/hooks/usePoll.ts",
        "src/hooks/usePollCache.ts",
        "src/hooks/useQueue.ts",
        "src/hooks/useStorage.ts",
        "src/hooks/useTimeline.ts",
        "src/hooks/useTradingPairs.ts",

        // ── BUILD-AHEAD: contexts, lib utilities, stores ──────────────────────
        "src/contexts/EventContext.tsx",            // event-bus context (provider not yet mounted)
        "src/lib/errorHandler.ts",                  // global unhandled-error util
        "src/lib/index.ts",                         // lib barrel (aggregates forms + react-query + sanitize)
        "src/lib/memoUtils.ts",                     // memoization helpers
        "src/lib/secureStorage.ts",                 // encrypted localStorage wrapper
        "src/stores/**",                            // Zustand stores (DEX order book, etc.)

        // ── BUILD-AHEAD: style sub-modules ────────────────────────────────────
        // GlobalStyles.ts and themes.ts are already connected via styles/index.ts → App.tsx.
        // These sub-modules are not yet re-exported and are awaiting component adoption.
        "src/styles/mixins.ts",
        "src/styles/modernTheme.ts",
        "src/styles/responsive.ts",
        "src/styles/tokens.ts",

        // ── AMBIENT TYPE DECLARATIONS ─────────────────────────────────────────
        // .d.ts files augment the global TypeScript environment; they are never imported.
        "src/styles/styled.d.ts",
        "src/types/charting_library.d.ts",
        "src/types/data-service.d.ts",

        // ── BUILD-AHEAD: type definitions ─────────────────────────────────────
        "src/types/api.ts",
        "src/types/common.ts",
        "src/types/components.ts",
        "src/types/index.ts",

        // ── BUILD-AHEAD: utility modules ──────────────────────────────────────
        "src/utils/componentList.ts",
        "src/utils/constants.ts",
        "src/utils/helpers.ts",
        "src/utils/index.ts",
        "src/utils/network.ts",
        "src/utils/seed.ts",
        "src/utils/storageExporter.ts",
        "src/utils/styleManager.ts",
        "src/utils/validators.ts",

        // ── STORYBOOK ─────────────────────────────────────────────────────────
        // Component story files — only consumed by Storybook, never by the app.
        "src/components/atoms/Button.stories.tsx",
        "src/components/atoms/Card.stories.tsx",
        "src/components/atoms/Input.stories.tsx"
      ],
      "project": ["src/**/*.{ts,tsx}", "test/**/*.{ts,tsx}"]
    },
    "apps/scanner": {
      "entry": ["src/pages/**/*.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/sdk/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    // tests are co-located in src/__tests__/ not test/
    "packages/sdk/assets-pairs-order": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/sdk/crypto": {
      "entry": ["src/index.ts"],
      // wasm-pack is a Rust binary tool (not an npm package) invoked via `wasm-pack build` in package scripts
      "ignoreBinaries": ["wasm-pack"],
      "project": ["src/**/*.ts"]
    },
    "packages/sdk/data-service-client-js": {
      "project": ["src/**/*.ts"]
    },
    "packages/sdk/node-api-js": {
      "entry": ["test/**/*.spec.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/sdk/protobuf-serialization": {
      "entry": ["src/index.ts"],
      "ignore": ["src/gen/**"],
      "project": ["src/**/*.ts"]
    },
    "packages/ride/ts": {
      "entry": ["src/index.js"],
      "project": ["src/**/*.{ts,js}"]
    },
    "packages/ride/lang/js": {
      "entry": ["dist/lang.js"],
      "project": ["dist/**/*.js"]
    },
    "packages/ride/repl/js": {
      "entry": ["dist/repl.js"],
      "project": ["dist/**/*.js"]
    }
  }
}
