{
  "author": "DecentralChain",
  "description": "DecentralChain SDK — Multi-language monorepo for all @decentralchain packages (TypeScript SDK, RIDE lang/repl, JVM libraries)",
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@nx/devkit": "23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/vitest": "23.0.1",
    "esbuild": "0.28.1",
    "knip": "6.24.0",
    "lefthook": "2.1.9",
    "nx": "23.0.1",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.17.0"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "license": "MIT",
  "name": "DecentralChain",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "bulletproof": "pnpm nx run-many -t biome-fix --exclude=data-service && pnpm run typecheck && pnpm run test",
    "bulletproof:check": "pnpm nx run-many -t biome-lint --exclude=data-service && pnpm run typecheck && pnpm run test",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "graph": "nx graph",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "prepare": "lefthook install",
    "test": "nx run-many -t test --exclude=data-service",
    "typecheck": "nx run-many -t typecheck --exclude=exchange,scanner,data-service"
  },
  "type": "module",
  "version": "0.0.0"
}
