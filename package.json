{
  "author": "DecentralChain",
  "description": "DecentralChain SDK — Unified TypeScript monorepo for all @decentralchain packages",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@nx/devkit": "22.7.1",
    "esbuild": "0.28.0",
    "knip": "6.11.0",
    "lefthook": "2.1.6",
    "nx": "22.7.1",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "license": "MIT",
  "name": "DecentralChain",
  "packageManager": "pnpm@10.33.3",
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom": ">=0.8.12",
      "basic-ftp": ">=5.2.1",
      "brace-expansion": ">=5.0.5",
      "defu": ">=6.1.5",
      "fast-xml-parser": ">=5.5.7",
      "lodash": ">=4.18.1",
      "path-to-regexp": ">=0.1.13",
      "picomatch": ">=4.0.4",
      "typescript": "$typescript",
      "yaml": ">=2.8.3",
      "yauzl": "^3.2.1"
    },
    "ignoredBuiltDependencies": [
      "@bufbuild/buf",
      "@evilmartians/lefthook",
      "electron",
      "esbuild",
      "lefthook",
      "nx"
    ]
  },
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "bulletproof": "pnpm nx run-many -t biome-fix --exclude=data-service && pnpm run typecheck && pnpm run test",
    "bulletproof:check": "pnpm nx run-many -t biome-lint --exclude=data-service && pnpm run typecheck && pnpm run test",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "graph": "nx graph",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "prepare": "lefthook install",
    "test": "nx run-many -t test --exclude=data-service",
    "typecheck": "nx run-many -t typecheck --exclude=exchange,scanner,data-service"
  },
  "type": "module",
  "version": "0.0.0"
}
