{
  "author": "DecentralChain",
  "description": "DecentralChain SDK — Multi-language monorepo for all @decentralchain packages (TypeScript SDK, RIDE lang/repl, JVM libraries)",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@nx/devkit": "22.7.1",
    "esbuild": "0.28.0",
    "knip": "6.13.1",
    "lefthook": "2.1.6",
    "nx": "22.7.1",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "license": "MIT",
  "name": "DecentralChain",
  "packageManager": "pnpm@11.1.1",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "bulletproof": "pnpm nx run-many -t biome-fix --exclude=data-service && pnpm run typecheck && pnpm run test",
    "bulletproof:check": "pnpm nx run-many -t biome-lint --exclude=data-service && pnpm run typecheck && pnpm run test",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "graph": "nx graph",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "prepare": "lefthook install",
    "test": "nx run-many -t test --exclude=data-service",
    "typecheck": "nx run-many -t typecheck --exclude=exchange,scanner,data-service"
  },
  "type": "module",
  "version": "0.0.0"
}
