{
  "author": "DecentralChain",
  "description": "DecentralChain SDK — Multi-language monorepo for all @decentralchain packages (TypeScript SDK, RIDE lang/repl, JVM libraries)",
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@nx/devkit": "22.7.5",
    "@nx/playwright": "22.7.5",
    "@nx/vitest": "22.7.5",
    "@sentry/vite-plugin": "5.3.0",
    "esbuild": "0.28.0",
    "knip": "6.14.2",
    "lefthook": "2.1.9",
    "nx": "22.7.5",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "license": "MIT",
  "name": "DecentralChain",
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "bulletproof": "pnpm nx run-many -t biome-fix --exclude=data-service && pnpm run typecheck && pnpm run test",
    "bulletproof:check": "pnpm nx run-many -t biome-lint --exclude=data-service && pnpm run typecheck && pnpm run test",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "graph": "nx graph",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "prepare": "lefthook install",
    "test": "nx run-many -t test --exclude=data-service",
    "typecheck": "nx run-many -t typecheck --exclude=exchange,scanner,data-service"
  },
  "type": "module",
  "version": "0.0.0"
}
