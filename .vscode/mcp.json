{
  "inputs": [],
  "servers": {
    "atlassian-mcp-server": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "chrome-devtools": {
      "args": ["chrome-devtools-mcp@latest", "--browserUrl=http://127.0.0.1:9222"],
      "command": "npx"
    },
    "context7": {
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "command": "npx",
      "type": "stdio"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "nx": {
      "args": ["nx", "mcp"],
      "command": "npx",
      "type": "stdio"
    }
  }
}
