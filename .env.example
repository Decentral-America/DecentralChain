# ─── DCC Test Environment ───────────────────────────────────────────
# Copy to `.env` and fill in real values from your private node genesis.
# .env is gitignored — NEVER commit real seeds.
#
# These env vars are consumed by:
#   - apps/cubensis-connect/test/  (E2E / WebDriverIO tests)
#   - packages/sdk/transactions/test/ (integration + proto-serialize tests)
#
# For local development, start the private node:
#   docker run -d --name dcc-node -p 6869:6869 ghcr.io/decentral-america/node-scala-private:latest
#
# The values below come from the private node's genesis config.
# ─────────────────────────────────────────────────────────────────────

# ── Node connection ──────────────────────────────────────────────────
DCC_TEST_NODE_URL=http://localhost:6869
DCC_TEST_CHAIN_ID=R
DCC_TEST_MATCHER_URL=http://localhost:6886
DCC_TEST_MATCHER_PUBLIC_KEY=

# ── Test account seeds (from genesis block) ──────────────────────────
# Rich account — has DCC tokens. This is the default baked into the
# private node Docker image (ghcr.io/decentral-america/node-scala-private).
# Address: 3MNXvMCn9FxPPjc4oe9oRGUSMDBXoQvUAdr
DCC_TEST_MINER_SEED=dcc private node seed with dcc tokens
# Poor account — no DCC tokens
DCC_TEST_POOR_SEED=
# Issuer — receives tokens from generator
DCC_TEST_ISSUER_SEED=
# Test users
DCC_TEST_USER_1_SEED=
DCC_TEST_USER_2_SEED=

# ── Extra test accounts (multi-account UI tests in cubensis-connect) ─
DCC_TEST_EXTRA_SEED=
DCC_TEST_EXTRA_3_SEED=

# ── Exchange / order serialization tests ─────────────────────────────
# Arbitrary seeds for deterministic key derivation in unit tests.
# Use any valid mnemonic — these accounts do NOT need to be funded.
DCC_TEST_EXCHANGE_SEED_1=
DCC_TEST_EXCHANGE_SEED_2=

# ── Crypto verification regression anchors ──────────────────────────
# A seed + its known-good derived keys/addresses for regression testing.
# Generate once: set seed, run publicKey/privateKey/address, record outputs.
DCC_TEST_CRYPTO_VERIFY_SEED=
DCC_TEST_CRYPTO_VERIFY_PUBKEY=
DCC_TEST_CRYPTO_VERIFY_PRIVKEY=
DCC_TEST_CRYPTO_VERIFY_ADDR_W=
DCC_TEST_CRYPTO_VERIFY_ADDR_Q=

# ── ts-lib-crypto embedded seed regression test ─────────────────────
# A seed + its known-good address for the embeded-seed.spec.ts test.
DCC_TEST_EMBEDDED_SEED=
DCC_TEST_EMBEDDED_ADDR=
