{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/DecentralChain/issues"
  },
  "dependencies": {
    "@decentralchain/bignumber": "workspace:*",
    "@decentralchain/marshall": "workspace:*",
    "@decentralchain/node-api": "workspace:*",
    "@decentralchain/protobuf-schemas": "workspace:*",
    "@decentralchain/transactions": "workspace:*",
    "@decentralchain/ts-lib-crypto": "workspace:*",
    "@decentralchain/types": "workspace:*",
    "@react-router/node": "7.16.0",
    "@react-router/serve": "7.16.0",
    "@tanstack/react-query": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5.1.43",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.16.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "description": "Private admin dashboard for DecentralChain node operators and super admins",
  "devDependencies": {
    "@evilmartians/lefthook": "^2.1.9",
    "@react-router/dev": "7.16.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "catalog:",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "homepage": "https://github.com/Decentral-America/DecentralChain/tree/main/apps/node-dashboard",
  "license": "MIT",
  "name": "admin-dashboard",
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/build"
        ]
      },
      "test": {
        "inputs": [
          "default",
          "^production"
        ],
        "outputs": [
          "{projectRoot}/coverage"
        ]
      },
      "ci:check": {
        "cache": false,
        "dependsOn": [
          "build"
        ],
        "inputs": [
          "default",
          "^production"
        ]
      }
    },
    "tags": [
      "scope:app",
      "layer:5"
    ]
  },
  "private": true,
  "repository": {
    "directory": "apps/node-dashboard",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/DecentralChain.git"
  },
  "scripts": {
    "build": "react-router build",
    "bulletproof": "pnpm run lint:fix && pnpm run typecheck && pnpm run test:run",
    "bulletproof:check": "pnpm run lint:check && pnpm run typecheck && pnpm run test:run",
    "ci:check": "cd ../.. && bash scripts/run-with-required-node.sh pnpm nx run node-dashboard:biome-lint --skip-nx-cache && bash scripts/run-with-required-node.sh pnpm nx run node-dashboard:typecheck --skip-nx-cache && bash scripts/run-with-required-node.sh pnpm nx run node-dashboard:test --skip-nx-cache && bash scripts/run-with-required-node.sh pnpm nx run node-dashboard:build --skip-nx-cache",
    "dev": "react-router dev",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "lefthook install",
    "preview": "react-router-serve build/server/index.js",
    "start": "react-router-serve build/server/index.js",
    "test": "vitest run --coverage",
    "release:gate": "pnpm run ci:check",
    "test:coverage": "vitest run --coverage",
    "test:fast": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "type": "module",
  "version": "1.0.0"
}
