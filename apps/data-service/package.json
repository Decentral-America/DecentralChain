{
  "name": "@decentralchain/data-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist/"
  ],
  "description": "DecentralChain data service — REST API for exchange data: candles, pairs, trades",
  "repository": {
    "type": "git",
    "url": "https://github.com/Decentral-America/DecentralChain"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "bulletproof": "pnpm run lint:fix && pnpm run typecheck && pnpm run test",
    "bulletproof:check": "pnpm run lint:check && pnpm run typecheck && pnpm run test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:check": "biome check src",
    "lint:fix": "biome check --write src",
    "start": "node dist/index.mjs",
    "dev": "NODE_ENV=development LOG_LEVEL=debug node dist/index.mjs",
    "pairs": "node dist/daemons/pairs/index.mjs",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:i": "export $(cat variables.env | xargs) && vitest run --config vitest.integration.config.ts",
    "test:it": "export $(cat variables.testnet.env | xargs) && vitest run --config vitest.integration.config.ts",
    "test:http": "vitest run --config vitest.http.config.ts"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/qs": "^6.15.1",
    "@types/ramda": "^0.32.0",
    "@vitest/coverage-v8": "^4.1.9",
    "pino-pretty": "^13.1.3",
    "tsdown": "catalog:",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@decentralchain/assets-pairs-order": "workspace:*",
    "@decentralchain/data-entities": "workspace:*",
    "@decentralchain/parse-json-bignumber": "workspace:*",
    "@hono/node-server": "^2.0.10",
    "effect": "^3.21.4",
    "hono": "^4.12.27",
    "knex": "^3.3.0",
    "lru-cache": "^11.5.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "qs": "^6.15.3",
    "ramda": "^0.32.0"
  }
}
