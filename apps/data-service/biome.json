{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "extends": "//",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "src/**/*.ts",
      "config/**/*.ts",
      "*.{ts,json}",
      "!dist",
      "!node_modules",
      "!src/@types",
      "!config/**/*.js"
    ]
  },
  "linter": {
    "domains": {
      "test": "recommended"
    },
    "rules": {
      "complexity": {
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedFunctionParameters": "error",
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "security": {
        "noGlobalEval": "error"
      },
      "style": {
        "useConst": "error",
        "useImportType": "error"
      },
      "suspicious": {
        "noConsole": {
          "level": "warn",
          "options": { "allow": ["warn", "error", "info"] }
        },
        "noExplicitAny": "off",
        "noImportCycles": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/__test__/**", "**/*.test.*", "**/*.spec.*"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off"
          },
          "suspicious": {
            "noImplicitAnyLet": "off",
            "noUnusedExpressions": "off"
          }
        }
      }
    },
    {
      "includes": ["**/repo/sql/**", "**/sql/**/*.ts"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off"
          }
        }
      }
    }
  ],
  "root": false,
  "vcs": {
    "clientKind": "git",
    "defaultBranch": "main",
    "enabled": true,
    "useIgnoreFile": true
  }
}
