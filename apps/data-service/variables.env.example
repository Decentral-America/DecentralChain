# data-service — Environment Variables
# Copy to variables.env and fill in values for local development.
# Required vars (checkEnv enforced): PGHOST, PGDATABASE, PGUSER, PGPASSWORD,
#   DEFAULT_MATCHER, RATE_PAIR_ACCEPTANCE_VOLUME_THRESHOLD, RATE_THRESHOLD_ASSET_ID

# ── PostgreSQL ───────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=dcc
PGUSER=dcc
PGPASSWORD=dcc_local
# PGSSLMODE=disable  # Set to 'disable' for local Docker PostgreSQL (no TLS)
# PGPOOLSIZE=20
# PGSTATEMENTTIMEOUT=

# ── Server ───────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=debug
NODE_ENV=development

# ── Matcher ──────────────────────────────────────────────────
DEFAULT_MATCHER=3MNXvMCn9FxPPjc4oe9oRGUSMDBXoQvUAdr
# MATCHER_SETTINGS_URL=

# ── Rate Engine ──────────────────────────────────────────────
RATE_PAIR_ACCEPTANCE_VOLUME_THRESHOLD=1
RATE_THRESHOLD_ASSET_ID=DCC
# RATE_BASE_ASSET_ID=DCC

# ── Pairs Daemon ─────────────────────────────────────────────
# PAIRS_UPDATE_INTERVAL=1000
# PAIRS_UPDATE_TIMEOUT=30000

# ── Misc ─────────────────────────────────────────────────────
# DOCS_URL=
