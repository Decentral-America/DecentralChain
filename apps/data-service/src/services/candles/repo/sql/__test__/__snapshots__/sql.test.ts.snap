exports[`sql query from candles > should search candles for 1d 1`] = `"select "c"."amount_asset_id" as "amount_asset_id", (c.close)::numeric as "close", (c.high)::numeric as "high", "c"."interval" as "interval", (c.low)::numeric as "low", "c"."max_height" as "max_height", (c.open)::numeric as "open", "c"."price_asset_id" as "price_asset_id", (c.quote_volume)::numeric as "quote_volume", "c"."time_start" as "time_start", "c"."txs_count" as "txs_count", (c.volume)::numeric as "volume", (c.weighted_average_price)::numeric as "weighted_average_price" from (select "c"."amount_asset_id" as "amount_asset_id", (c.close)::numeric as "close", (c.high)::numeric as "high", "c"."interval" as "interval", (c.low)::numeric as "low", "c"."max_height" as "max_height", (c.open)::numeric as "open", "c"."price_asset_id" as "price_asset_id", (c.quote_volume)::numeric as "quote_volume", "c"."time_start" as "time_start", "c"."txs_count" as "txs_count", (c.volume)::numeric as "volume", (c.weighted_average_price)::numeric as "weighted_average_price" from "candles" as "c" where "amount_asset_id" = '111' and "price_asset_id" = '222' and "time_start" >= '2017-04-03T00:00:00.000Z' and "time_start" <= '2017-04-03T23:59:59.999Z' and "matcher_address" = '123' and "interval" = '1d') as "c" order by "c"."time_start" asc"`;

