// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Sql search supports type-specific filters 1`] = `"select "t"."amount" as "amount", "t"."asset_id" as "asset_id", "t"."attachment" as "attachment", "t"."fee" as "fee", "t"."fee_asset_id" as "fee_asset", "t"."height" as "height", "t"."id" as "id", "t"."proofs" as "proofs", coalesce(t.recipient_alias, t.recipient_address) as "recipient", "t"."sender" as "sender", "t"."sender_public_key" as "sender_public_key", "t"."signature" as "signature", "t"."status" as "status", "t"."time_stamp" as "time_stamp", "t"."tx_type" as "tx_type", "t"."tx_version" as "tx_version", "t"."uid" as "uid" from "txs_4" as "t" where "asset_id" = 'someAssetID' and recipient_address = coalesce((select sender from txs_10 where alias = 'recipient' limit 1), 'recipient')"`;
