// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Sql search supports type-specific filters 1`] = `"select "tfs"."amount" as "amount", "t"."asset_id" as "asset_id", "t"."attachment" as "attachment", "t"."fee" as "fee", "t"."height" as "height", "t"."id" as "id", "tfs"."position_in_tx" as "position_in_tx", "t"."proofs" as "proofs", "tfs"."recipient_address" as "recipient_address", "tfs"."recipient_alias" as "recipient_alias", "t"."sender" as "sender", "t"."sender_public_key" as "sender_public_key", "t"."signature" as "signature", "t"."status" as "status", "t"."time_stamp" as "time_stamp", "t"."tx_type" as "tx_type", "t"."tx_version" as "tx_version", "t"."uid" as "uid" from "txs_11" as "t" left join "txs_11_transfers" as "tfs" on "tfs"."tx_uid" = "t"."uid" where "t"."uid" in (select "t"."uid" from "txs_11" as "t" left join "txs_11_transfers" as "tfs" on "tfs"."tx_uid" = "t"."uid" where "asset_id" = 'assetId' and tfs.recipient_address = coalesce((select sender from txs_10 where alias = 'recipient' limit 1), 'recipient') group by "t"."uid")"`;
