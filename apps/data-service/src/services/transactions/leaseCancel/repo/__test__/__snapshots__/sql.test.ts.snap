// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Sql search by type-specific filters > supports recipient filter 1`] = `"select "t"."fee" as "fee", "t"."height" as "height", "t"."id" as "id", "l"."id" as "lease_id", "t"."proofs" as "proofs", "t"."sender" as "sender", "t"."sender_public_key" as "sender_public_key", "t"."signature" as "signature", "t"."status" as "status", "t"."time_stamp" as "time_stamp", "t"."tx_type" as "tx_type", "t"."tx_version" as "tx_version", "t"."uid" as "uid" from "txs_9" as "t" left join "txs_8" as "l" on "l"."uid" = "lease_tx_uid" where "lease_tx_uid" in (select "uid" from "txs_8" where recipient_address = coalesce((select sender from txs_10 where alias = 'recipient' limit 1), 'recipient')) order by "t"."uid" desc limit 100"`;
