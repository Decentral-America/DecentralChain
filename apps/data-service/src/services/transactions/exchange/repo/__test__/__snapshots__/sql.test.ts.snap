// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Sql search supports type-specific filters 1`] = `"select "t"."amount" as "amount", "t"."amount_asset_id" as "amount_asset", "t"."buy_matcher_fee" as "buy_matcher_fee", "t"."fee" as "fee", "t"."height" as "height", "t"."id" as "id", (t.order1->>'amount')::double precision as "o1_amount", t.order1->>'eip712Signature' as "o1_eip712signature", text_timestamp_cast(t.order1->>'expiration') as "o1_expiration", t.order1->>'id' as "o1_id", (t.order1->>'matcherFee')::double precision as "o1_matcher_fee", t.order1->>'matcherFeeAssetId' as "o1_matcher_fee_asset_id", (t.order1->>'price')::double precision as "o1_price", t.order1->>'priceMode' as "o1_price_mode", t.order1->>'sender' as "o1_sender", t.order1->>'senderPublicKey' as "o1_sender_public_key", t.order1->>'signature' as "o1_signature", text_timestamp_cast(t.order1->>'timestamp') as "o1_time_stamp", t.order1->>'orderType' as "o1_type", t.order1->>'version' as "o1_version", (t.order2->>'amount')::double precision as "o2_amount", t.order2->>'eip712Signature' as "o2_eip712signature", text_timestamp_cast(t.order2->>'expiration') as "o2_expiration", t.order2->>'id' as "o2_id", (t.order2->>'matcherFee')::double precision as "o2_matcher_fee", t.order2->>'matcherFeeAssetId' as "o2_matcher_fee_asset_id", (t.order2->>'price')::double precision as "o2_price", t.order2->>'priceMode' as "o2_price_mode", t.order2->>'sender' as "o2_sender", t.order2->>'senderPublicKey' as "o2_sender_public_key", t.order2->>'signature' as "o2_signature", text_timestamp_cast(t.order2->>'timestamp') as "o2_time_stamp", t.order2->>'orderType' as "o2_type", t.order2->>'version' as "o2_version", "t"."price" as "price", "t"."price_asset_id" as "price_asset", "t"."proofs" as "proofs", "t"."sell_matcher_fee" as "sell_matcher_fee", "t"."sender" as "sender", "t"."sender_public_key" as "sender_public_key", "t"."signature" as "signature", "t"."status" as "status", "t"."time_stamp" as "time_stamp", "t"."tx_type" as "tx_type", "t"."tx_version" as "tx_version", "t"."uid" as "uid" from ((select * from "txs_7" as "t" where "t"."sender" = 'matcher' and "t"."amount_asset_id" = 'amountAsset' and "t"."price_asset_id" = 'priceAsset' and t.order1->>'sender' = 'sender') union (select * from "txs_7" as "t" where "t"."sender" = 'matcher' and "t"."amount_asset_id" = 'amountAsset' and "t"."price_asset_id" = 'priceAsset' and t.order2->>'sender' = 'sender')) as "t" order by "t"."uid" desc"`;
