// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`pairs daemon sql test > fill table 1`] = `
"insert into "pairs" with "pairs_cte" as (select "amount_asset_id" as "amount_asset_id", (array_agg(e.price ORDER BY e.uid)::numeric[])[1] as "first_price", max(e.price) as "high", (array_agg(e.price ORDER BY e.uid DESC)::numeric[])[1] as "last_price", min(e.price) as "low", "sender" as "matcher_address", "price_asset_id" as "price_asset_id", sum(e.amount::numeric * e.price::numeric) as "quote_volume", count(e.price) as "txs_count", sum(e.amount) as "volume", case when amount_asset_id='DCC' then sum(e.amount) when price_asset_id='DCC' then sum(e.amount::numeric * e.price::numeric) end as "volume_dcc", floor(sum(e.amount::numeric * e.price::numeric)/ sum(e.amount)) as "weighted_average_price" from (select "t"."amount" as "amount", "t"."amount_asset_id" as "amount_asset_id", 
      CASE WHEN t.tx_version > 2
        THEN t.price::numeric
          * 10^(select decimals from decimals where asset_id = t.price_asset_id)
          * 10^(select -decimals from decimals where asset_id = t.amount_asset_id)
        ELSE t.price::numeric
      END
     as "price", "t"."price_asset_id" as "price_asset_id", "t"."sender" as "sender", "t"."time_stamp" as "time_stamp", "t"."uid" as "uid" from "txs_7" as "t" where time_stamp >= now() - interval '1 day' order by "t"."uid" desc, time_stamp <-> now() - interval '1 day') as "e" group by "amount_asset_id", "price_asset_id", "sender") select "p"."amount_asset_id", "p"."price_asset_id", "p"."first_price", "p"."last_price", "p"."volume", COALESCE(p.volume_dcc, floor(p.quote_volume / p1.weighted_average_price), p.quote_volume * p2.weighted_average_price) as "volume_dcc", "p"."quote_volume", "p"."high", "p"."low", "p"."weighted_average_price", "p"."txs_count", "p"."matcher_address" from "pairs_cte" as "p" left join "pairs_cte" as "p1" on p1.amount_asset_id='DCC' and "p1"."price_asset_id" = "p"."price_asset_id" and "p1"."matcher_address" = "p"."matcher_address" left join "pairs_cte" as "p2" on "p2"."amount_asset_id" = "p"."price_asset_id" and p2.price_asset_id='DCC' and "p2"."matcher_address" = "p"."matcher_address""
`;
