/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# HTML entry point — never cache; always fetch fresh so new chunk hashes are picked up
/
  Cache-Control: no-cache, no-store, must-revalidate

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Hashed assets — cache forever; content hash guarantees freshness
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Locale files versioned via ?v= query param — short cache to allow updates
/locales/*
  Cache-Control: public, max-age=3600, must-revalidate
