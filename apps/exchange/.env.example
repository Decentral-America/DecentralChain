# DecentralExchange — Environment Variables
# Copy to .env.local and fill in values for local development.
# See .env.production / .env.testnet / .env.staging for per-environment defaults.

# ── Application ──────────────────────────────────────────────
VITE_APP_ENV=development
VITE_APP_VERSION=0.0.0
VITE_DEBUG=true
VITE_ENABLE_MOCKS=false

# ── Network ──────────────────────────────────────────────────
# mainnet = ?, testnet = !, stagenet = S
VITE_NETWORK=mainnet
VITE_NETWORK_BYTE=?

# ── Service URLs ─────────────────────────────────────────────
VITE_NODE_URL=https://mainnet-node.decentralchain.io
VITE_MATCHER_URL=https://mainnet-matcher.decentralchain.io/matcher
VITE_API_URL=https://data-service.decentralchain.io
VITE_DATA_SERVICE_URL=https://data-service.decentralchain.io
VITE_EXPLORER_URL=https://decentralscan.com

# ── Error Monitoring (Sentry) ────────────────────────────────
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN=

# ── Analytics (optional) ─────────────────────────────────────
VITE_GA_MEASUREMENT_ID=
VITE_AMPLITUDE_KEY=
