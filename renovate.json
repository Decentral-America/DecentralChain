{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "group:monorepos", ":semanticCommitTypeAll(chore)"],
  "labels": ["dependencies"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "automerge": false,
      "description": "Group all Nx packages together",
      "groupName": "Nx monorepo",
      "matchPackageNames": ["nx", "@nx/**", "@nrwl/**"]
    },
    {
      "automerge": false,
      "description": "Group Biome updates",
      "groupName": "Biome",
      "matchPackageNames": ["@biomejs/biome"]
    },
    {
      "automerge": true,
      "description": "Automerge non-major devDependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "automerge": true,
      "description": "Automerge patch-level production dependencies",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["patch"]
    },
    {
      "description": "Group tsdown updates",
      "groupName": "tsdown",
      "matchPackageNames": ["tsdown"]
    },
    {
      "description": "Group Vitest ecosystem",
      "groupName": "Vitest",
      "matchPackageNames": ["vitest", "@vitest/**"]
    },
    {
      "description": "Group Vite ecosystem",
      "groupName": "Vite",
      "matchPackageNames": ["vite", "@vitejs/**"]
    },
    {
      "description": "Prevent npm unpublish risk",
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "3 days"
    }
  ],
  "pnpm": {
    "updateCatalog": true
  },
  "postUpdateOptions": ["pnpmDedupe"],
  "prConcurrentLimit": 5,
  "schedule": ["before 4am on monday"]
}
