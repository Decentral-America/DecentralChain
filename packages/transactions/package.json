{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/decentralchain-sdk/issues"
  },
  "dependencies": {
    "@decentralchain/marshall": "workspace:*",
    "@decentralchain/protobuf-serialization": "workspace:*",
    "@decentralchain/ts-lib-crypto": "workspace:*",
    "@decentralchain/ts-types": "workspace:*"
  },
  "description": "Build and sign (multi-sign) transactions for the DecentralChain blockchain.",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.6",
    "@evilmartians/lefthook": "2.1.3",
    "@size-limit/preset-small-lib": "12.0.0",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsdown": "0.21.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/decentralchain-sdk/tree/main/packages/transactions",
  "keywords": [
    "decentralchain",
    "dcc",
    "transactions",
    "crypto",
    "blockchain",
    "protocol",
    "binary",
    "cryptography",
    "signature"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/transactions",
  "nx": {
    "implicitDependencies": [
      "!@decentralchain/node-api-js"
    ],
    "tags": [
      "scope:sdk",
      "layer:2"
    ]
  },
  "peerDependencies": {
    "@decentralchain/node-api-js": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/transactions",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/decentralchain-sdk.git"
  },
  "scripts": {
    "build": "tsdown",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "postpublish": "git push",
    "postversion": "npm publish",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "limit": "150 kB",
      "path": "./dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "5.0.1"
}
