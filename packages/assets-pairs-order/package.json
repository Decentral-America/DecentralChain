{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/decentralchain-sdk/issues"
  },
  "dependencies": {
    "bs58": "^6.0.0"
  },
  "description": "Deterministic asset-pair ordering for the DecentralChain decentralized exchange (DEX). Resolves canonical amount/price asset direction using network priority lists.",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@size-limit/preset-small-lib": "12.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsdown": "0.21.2",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/decentralchain-sdk/tree/main/packages/assets-pairs-order",
  "keywords": [
    "decentralchain",
    "dcc",
    "dex",
    "decentralized-exchange",
    "assets",
    "pairs",
    "order",
    "trading",
    "blockchain",
    "cryptocurrency",
    "matcher",
    "order-book",
    "asset-pair",
    "deterministic"
  ],
  "license": "MIT",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/assets-pairs-order",
  "nx": {
    "tags": [
      "scope:sdk",
      "layer:0"
    ]
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/assets-pairs-order",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/decentralchain-sdk.git"
  },
  "scripts": {
    "build": "tsdown",
    "build:browser": "tsdown",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "npm run build",
    "prepublishOnly": "npm run validate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "limit": "5 kB",
      "path": "./dist/index.global.js"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "5.0.2"
}
