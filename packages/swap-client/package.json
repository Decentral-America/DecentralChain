{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/decentralchain-sdk/issues"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@decentralchain/bignumber": "workspace:*",
    "long": "^5.3.2",
    "nanoid": "^5.1.5",
    "protobufjs": "^7.4.0"
  },
  "description": "WebSocket client for DecentralChain token swap aggregation — get the best swap prices across multiple DEX vendors",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@bufbuild/buf": "1.66.1",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@size-limit/preset-small-lib": "12.0.0",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.0.18",
    "jsdom": "^28.1.0",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsdown": "0.21.2",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/decentralchain-sdk/tree/main/packages/swap-client",
  "keywords": [
    "decentralchain",
    "dcc",
    "swap",
    "dex",
    "aggregator",
    "websocket",
    "protobuf",
    "token-swap",
    "defi",
    "blockchain",
    "web3"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/swap-client",
  "nx": {
    "tags": [
      "scope:sdk",
      "layer:1"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/swap-client",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/decentralchain-sdk.git"
  },
  "scripts": {
    "build": "tsdown",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "generate": "buf generate",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "postpublish": "git push",
    "postversion": "npm publish",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "limit": "50 kB",
      "path": "./dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "2.0.0"
}
