{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/decentralchain-sdk/issues"
  },
  "dependencies": {
    "@decentralchain/ts-lib-crypto": "workspace:*",
    "@waves/ride-lang": "1.6.1",
    "@waves/ride-repl": "1.6.1"
  },
  "description": "JS compiler for Ride - the smart-contract language for DecentralChain",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@size-limit/preset-small-lib": "12.0.0",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsdown": "0.21.2",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/decentralchain-sdk/tree/main/packages/ride-js",
  "keywords": [
    "decentralchain",
    "dcc",
    "blockchain",
    "ride",
    "compiler",
    "smart-contracts",
    "decentralchain-sdk",
    "ride-language",
    "decompile",
    "ride-compiler"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/ride-js",
  "nx": {
    "tags": [
      "scope:sdk",
      "layer:1"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/ride-js",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/decentralchain-sdk.git"
  },
  "scripts": {
    "build": "tsdown",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "postpublish": "git push",
    "postversion": "npm publish",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": true,
  "size-limit": [
    {
      "ignore": [
        "@waves/ride-lang",
        "@waves/ride-repl",
        "@decentralchain/ts-lib-crypto"
      ],
      "limit": "10 kB",
      "path": "./dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "2.3.1"
}
