{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/DecentralChain/issues"
  },
  "dependencies": {
    "bignumber.js": "^11.1.4"
  },
  "description": "Official arbitrary-precision BigNumber library for the DecentralChain blockchain SDK — safe arithmetic and byte serialization for token amounts, transaction fees, and on-chain financial computations",
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@size-limit/preset-small-lib": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "long": "^5.3.2",
    "publint": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/DecentralChain/tree/main/packages/sdk/bignumber",
  "keywords": [
    "bignumber",
    "bigint",
    "arbitrary-precision",
    "blockchain",
    "decentralchain",
    "sdk",
    "math",
    "decimal",
    "defi",
    "cryptocurrency",
    "token",
    "transaction",
    "serialization",
    "financial",
    "precision"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/bignumber",
  "nx": {
    "tags": [
      "scope:sdk",
      "layer:0"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/sdk/bignumber",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/DecentralChain.git"
  },
  "scripts": {
    "build": "tsdown",
    "bulletproof": "pnpm run lint:fix && pnpm run typecheck && pnpm run test",
    "bulletproof:check": "pnpm run lint:check && pnpm run typecheck && pnpm run test",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "2.0.0"
}
