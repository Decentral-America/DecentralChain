{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/DecentralChain/issues"
  },
  "dependencies": {
    "@connectrpc/connect": "2.1.1",
    "@connectrpc/connect-node": "2.1.1",
    "@decentralchain/protobuf-schemas": "workspace:*"
  },
  "description": "TypeScript gRPC client for the DecentralChain node gRPC APIs — AccountsApi, AssetsApi, BlockchainApi, BlocksApi, TransactionsApi, BlockchainUpdatesApi",
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/DecentralChain/tree/main/packages/sdk/node-api-grpc",
  "keywords": [
    "decentralchain",
    "dcc",
    "grpc",
    "blockchain",
    "node-api",
    "connect",
    "protobuf",
    "web3",
    "typescript"
  ],
  "license": "MIT",
  "main": "./dist/index.mjs",
  "name": "@decentralchain/node-api-grpc",
  "nx": {
    "targets": {
      "biome-lint": {
        "inputs": [
          "{projectRoot}/**/*"
        ]
      },
      "build": {
        "inputs": [
          "{projectRoot}/**/*",
          "^{projectRoot}/**/*"
        ]
      },
      "typecheck": {
        "inputs": [
          "{projectRoot}/**/*",
          "^{projectRoot}/**/*"
        ]
      }
    },
    "tags": [
      "scope:sdk",
      "layer:1"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/sdk/node-api-grpc",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/DecentralChain.git"
  },
  "scripts": {
    "build": "rm -rf dist && tsdown",
    "bulletproof": "pnpm run lint:fix && pnpm run typecheck && pnpm run test",
    "bulletproof:check": "pnpm run lint:check && pnpm run typecheck && pnpm run test",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "lint": "biome check .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run validate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run check:publint && pnpm run check:exports"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "2.0.0"
}
