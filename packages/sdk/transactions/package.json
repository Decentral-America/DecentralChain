{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/DecentralChain/issues"
  },
  "dependencies": {
    "@decentralchain/marshall": "workspace:*",
    "@decentralchain/protobuf-schemas": "workspace:*",
    "@decentralchain/ts-lib-crypto": "workspace:*",
    "@decentralchain/types": "workspace:*",
    "@ethereumjs/rlp": "^10.1.2"
  },
  "description": "Build and sign (multi-sign) transactions for the DecentralChain blockchain.",
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@decentralchain/node-api": "workspace:*",
    "@size-limit/preset-small-lib": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "publint": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/DecentralChain/tree/main/packages/sdk/transactions",
  "keywords": [
    "decentralchain",
    "dcc",
    "transactions",
    "crypto",
    "blockchain",
    "protocol",
    "binary",
    "cryptography",
    "signature"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/transactions",
  "nx": {
    "implicitDependencies": [
      "!@decentralchain/node-api"
    ],
    "tags": [
      "scope:sdk",
      "layer:2"
    ]
  },
  "peerDependencies": {
    "@decentralchain/node-api": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/sdk/transactions",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/DecentralChain.git"
  },
  "scripts": {
    "build": "tsdown",
    "bulletproof": "pnpm run lint:fix && pnpm run typecheck && pnpm run test",
    "bulletproof:check": "pnpm run lint:check && pnpm run typecheck && pnpm run test",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "6.0.0"
}
