{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/DecentralChain/issues"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0"
  },
  "description": "Official Protocol Buffers schema definitions and multi-language bindings for the DecentralChain blockchain protocol — encoding/decoding transactions, blocks, events, and gRPC APIs.",
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@bufbuild/buf": "1.70.0",
    "@bufbuild/protoc-gen-es": "2.12.0",
    "@size-limit/preset-small-lib": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "publint": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./grpc": {
      "types": "./dist/grpc.d.mts",
      "default": "./dist/grpc.mjs"
    },
    "./proto/*": "./proto/*"
  },
  "files": [
    "dist",
    "proto",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/DecentralChain/tree/main/packages/sdk/protobuf-schemas",
  "keywords": [
    "decentralchain",
    "dcc",
    "protobuf",
    "serialization",
    "blockchain",
    "grpc",
    "protocol-buffers",
    "proto",
    "schema",
    "transactions",
    "dapp",
    "smart-contracts",
    "web3",
    "decentralized",
    "binary-encoding"
  ],
  "license": "MIT",
  "main": "./dist/index.mjs",
  "name": "@decentralchain/protobuf-schemas",
  "nx": {
    "namedInputs": {
      "tsInputs": [
        "{projectRoot}/**/*",
        "!{projectRoot}/pom.xml",
        "!{projectRoot}/mvnw",
        "!{projectRoot}/.mvn/**",
        "!{projectRoot}/target/**",
        "!{projectRoot}/src/main/java/**",
        "!{projectRoot}/src/main/proto/**",
        "!{projectRoot}/src/test/**"
      ]
    },
    "targets": {
      "build": {
        "inputs": [
          "tsInputs",
          "^tsInputs"
        ]
      },
      "typecheck": {
        "inputs": [
          "tsInputs",
          "^tsInputs"
        ]
      },
      "biome-lint": {
        "inputs": [
          "tsInputs"
        ]
      }
    },
    "tags": [
      "scope:sdk",
      "layer:0"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/sdk/protobuf-schemas",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/DecentralChain.git"
  },
  "scripts": {
    "build": "rm -rf dist && buf generate && tsdown",
    "bulletproof": "pnpm run lint:fix && pnpm run typecheck && pnpm run test",
    "bulletproof:check": "pnpm run lint:check && pnpm run typecheck && pnpm run test",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "generate": "buf generate",
    "lint": "biome check .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run validate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run check:publint && pnpm run check:exports && pnpm run check:size"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "3.0.0"
}
