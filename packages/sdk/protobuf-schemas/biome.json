{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "extends": "//",
  "overrides": [
    {
      "assist": {
        "enabled": false
      },
      "formatter": {
        "enabled": false
      },
      "includes": ["src/gen/**"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off"
          },
          "style": {
            "useImportType": "off"
          }
        }
      }
    }
  ],
  "root": false
}
