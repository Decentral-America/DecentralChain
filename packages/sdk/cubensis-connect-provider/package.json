  },
  "dependencies": {
    "@decentralchain/cubensis-connect-types": "workspace:*",
    "@decentralchain/marshall": "workspace:*",
    "typed-ts-events": "^3.0.1"
  },
  "description": "CubensisConnect provider for DCC Signer — browser wallet integration for DecentralChain",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@decentralchain/signer": "workspace:*",
    "@size-limit/preset-small-lib": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "publint": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "0.22.1",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/DecentralChain/tree/main/packages/sdk/cubensis-connect-provider",
  "keywords": [
    "decentralchain",
    "dcc",
    "signer",
    "provider",
    "cubensis-connect",
    "blockchain",
    "wallet"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/cubensis-connect-provider",
  "nx": {
    "tags": [
      "scope:sdk",
      "layer:4"
    ]
  },
  "peerDependencies": {
    "@decentralchain/signer": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/sdk/cubensis-connect-provider",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/DecentralChain.git"
  },
  "scripts": {
    "build": "tsdown",
    "bulletproof": "pnpm run lint:fix && pnpm run typecheck && pnpm run test",
    "bulletproof:check": "pnpm run lint:check && pnpm run typecheck && pnpm run test",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "1.0.1"
