{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/DecentralChain/issues"
  },
  "dependencies": {
    "@decentralchain/ts-lib-crypto": "workspace:*",
    "@decentralchain/ride-lang": "workspace:*",
    "@decentralchain/ride-repl": "workspace:*"
  },
  "description": "JS compiler for Ride - the smart-contract language for DecentralChain",
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@size-limit/preset-small-lib": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "publint": "catalog:",
    "size-limit": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/DecentralChain/tree/main/packages/ride/ts",
  "keywords": [
    "decentralchain",
    "dcc",
    "blockchain",
    "ride",
    "compiler",
    "smart-contracts",
    "DecentralChain",
    "ride-language",
    "decompile",
    "ride-compiler"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/ride-js",
  "nx": {
    "tags": [
      "scope:ride",
      "layer:1"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/ride/ts",
    "type": "git",
    "url": "git+https://github.com/Decentral-America/DecentralChain.git"
  },
  "scripts": {
    "build": "tsdown && cp src/index.d.ts dist/index.d.mts",
    "dev:build-js": "cd .. && sbt fullLinkJS",
    "bulletproof": "pnpm run lint:fix && pnpm run typecheck && pnpm run test",
    "bulletproof:check": "pnpm run lint:check && pnpm run typecheck && pnpm run test",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "lint": "biome check .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": true,
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "2.3.1"
}
