{
  "name": "ride",
  "projectType": "library",
  "tags": ["scope:ride", "layer:0", "lang:scala"],
  "targets": {
    "bulletproof": {
      "configurations": {
        "ci": {
          "command": "sbt --no-colors bulletproof"
        }
      },
      "executor": "nx:run-commands",
      "options": {
        "command": "sbt bulletproof",
        "cwd": "packages/ride"
      }
    },
    "compile": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sbt compile",
        "cwd": "packages/ride"
      }
    },
    "coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sbt coverage test coverageReport",
        "cwd": "packages/ride"
      }
    },
    "fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sbt scalafixAll",
        "cwd": "packages/ride"
      }
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sbt scalafmtAll scalafmtSbt",
        "cwd": "packages/ride"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sbt scalafmtCheckAll scalafmtSbtCheck",
        "cwd": "packages/ride"
      }
    },
    "fullLinkJS": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sbt fullLinkJS",
        "cwd": "packages/ride"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sbt test",
        "cwd": "packages/ride"
      }
    }
  }
}
