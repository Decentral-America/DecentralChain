<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <!-- ── Coordinates ──────────────────────────────────────────────────── -->
  <groupId>io.decentralchain</groupId>
  <artifactId>groth16</artifactId>
  <!--
    Version scheme: <upstream-groth16-version>.<dcc-patch>
    upstream 0.2.1 + DCC patch 0 → 0.2.1.0
  -->
  <version>0.2.1.0</version>
  <packaging>jar</packaging>

  <!-- ── Project metadata (required for Maven Central) ───────────────── -->
  <name>groth16</name>
  <description>
    Java JNI bindings for Decentral-America/DecentralChain (packages/jvm/groth16) — ZK-SNARK Groth16 verifier
    for BLS12-381 (Zcash Sapling) and BN256 (Ethereum/Zcash) curves.
    Used by the DecentralChain node to verify zero-knowledge proofs for
    private transactions and Layer-2 scaling constructs.
    Forked from Decentral-America/DecentralChain (packages/jvm/groth16) (upstream commit d4546dbb)
    with full upstream history and DCC production hardening.
  </description>
  <url>https://github.com/Decentral-America/DCC</url>
  <inceptionYear>2020</inceptionYear>

  <licenses>
    <license>
      <name>Apache License, Version 2.0</name>
      <url>https://www.apache.org/licenses/LICENSE-2.0.txt</url>
      <distribution>repo</distribution>
    </license>
  </licenses>

  <organization>
    <name>Decentral America</name>
    <url>https://decentralchain.io</url>
  </organization>

  <developers>
    <developer>
      <id>josue</id>
      <name>Josué</name>
      <organization>Decentral America</organization>
      <organizationUrl>https://decentralchain.io</organizationUrl>
    </developer>
  </developers>

  <scm>
    <connection>scm:git:https://github.com/Decentral-America/DCC.git</connection>
    <developerConnection>scm:git:ssh://git@github.com/Decentral-America/DCC.git</developerConnection>
    <url>https://github.com/Decentral-America/DCC/tree/main/packages/jvm/groth16</url>
    <tag>HEAD</tag>
  </scm>

  <issueManagement>
    <system>Jira</system>
    <url>https://decentralchain.atlassian.net</url>
  </issueManagement>

  <!-- ── Global properties ────────────────────────────────────────────── -->
  <properties>
    <!-- Java 25 — matches DecentralChain JVM ecosystem standard -->
    <maven.compiler.release>25</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

    <!-- Dependency version properties — pinned and audited 2026-05 -->
    <!-- junit-jupiter 5.14.4 — latest -->
    <junit.version>5.14.4</junit.version>
    <!-- assertj-core 3.27.7 — latest -->
    <assertj.version>3.27.7</assertj.version>

    <!-- Plugin versions — pinned and audited 2026-05 -->
    <!-- maven-compiler-plugin 3.15.0 — latest (Feb 2026) -->
    <maven-compiler-plugin.version>3.15.0</maven-compiler-plugin.version>
    <!-- maven-surefire-plugin 3.5.5 — latest -->
    <maven-surefire-plugin.version>3.5.5</maven-surefire-plugin.version>
    <!-- maven-source-plugin 3.4.0 — latest -->
    <maven-source-plugin.version>3.4.0</maven-source-plugin.version>
    <!-- maven-javadoc-plugin 3.12.0 — latest -->
    <maven-javadoc-plugin.version>3.12.0</maven-javadoc-plugin.version>
    <!-- maven-gpg-plugin 3.2.8 — latest -->
    <maven-gpg-plugin.version>3.2.8</maven-gpg-plugin.version>
    <!-- maven-enforcer-plugin 3.6.2 — latest -->
    <maven-enforcer-plugin.version>3.6.2</maven-enforcer-plugin.version>
    <!-- central-publishing-maven-plugin 0.10.0 — latest (Jan 2026) -->
    <central-publishing-maven-plugin.version>0.10.0</central-publishing-maven-plugin.version>
    <!-- dependency-check-maven 12.2.2 — latest -->
    <dependency-check-maven.version>12.2.2</dependency-check-maven.version>
    <!-- spotbugs-maven-plugin 4.9.8.3 — latest (Mar 28, 2026); SpotBugs 4.9.8 -->
    <spotbugs-maven-plugin.version>4.10.2.0</spotbugs-maven-plugin.version>
    <!-- findsecbugs-plugin 1.14.0 — latest (Jun 16, 2025; OWASP) -->
    <findsecbugs-plugin.version>1.14.0</findsecbugs-plugin.version>
    <!-- jacoco-maven-plugin 0.8.14 — latest; Java 25 officially supported -->
    <jacoco-maven-plugin.version>0.8.14</jacoco-maven-plugin.version>
    <!-- maven-pmd-plugin 3.28.0 — latest; bundles PMD 7.17.0 -->
    <maven-pmd-plugin.version>3.28.0</maven-pmd-plugin.version>
    <!-- cyclonedx-maven-plugin 2.9.1 — latest; supply-chain SBOM (CycloneDX 1.6) -->
    <cyclonedx-maven-plugin.version>2.9.1</cyclonedx-maven-plugin.version>
    <!-- Reproducible builds — set to release date on each release -->
    <project.build.outputTimestamp>2026-05-17T00:00:00Z</project.build.outputTimestamp>
  </properties>

  <!-- ── Dependencies ────────────────────────────────────────────────── -->
  <dependencies>

    <!-- JUnit Jupiter — test only -->
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>

    <!-- AssertJ — fluent assertions, test only -->
    <dependency>
      <groupId>org.assertj</groupId>
      <artifactId>assertj-core</artifactId>
      <version>${assertj.version}</version>
      <scope>test</scope>
    </dependency>

  </dependencies>

  <!-- ── Build plugins ────────────────────────────────────────────────── -->
  <build>
    <!--
      The upstream Decentral-America/DecentralChain (packages/jvm/groth16) Gradle project nests the Java library
      inside groth16_jni/javalib/. We keep this layout verbatim (git subtree)
      and point Maven at the correct source/resource/test directories.
    -->
    <sourceDirectory>${project.basedir}/groth16_jni/javalib/src/main/java</sourceDirectory>
    <resources>
      <resource>
        <directory>${project.basedir}/groth16_jni/javalib/src/main/resources</directory>
      </resource>
    </resources>
    <testSourceDirectory>${project.basedir}/groth16_jni/javalib/src/test/java</testSourceDirectory>

    <plugins>

      <!-- Enforcer: gate Java + Maven minimums before any compilation -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
        <version>${maven-enforcer-plugin.version}</version>
        <executions>
          <execution>
            <id>enforce-minimums</id>
            <goals><goal>enforce</goal></goals>
            <configuration>
              <rules>
                <requireJavaVersion>
                  <version>[25,)</version>
                  <message>Java 25 or later is required.</message>
                </requireJavaVersion>
                <requireMavenVersion>
                  <version>[3.9,)</version>
                  <message>Maven 3.9 or later is required.</message>
                </requireMavenVersion>
              </rules>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <!-- Compiler: release 25 -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>${maven-compiler-plugin.version}</version>
        <configuration>
          <release>25</release>
          <encoding>UTF-8</encoding>
        </configuration>
      </plugin>

      <!-- Surefire: JUnit Platform auto-detected -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>${maven-surefire-plugin.version}</version>
        <configuration>
          <!--
            The JNI dylib embedded in resources is unpacked at runtime by the
            ZDccJNILibrary static initializer. Fork the JVM so the extraction
            works correctly in CI and local builds alike.
          -->
          <forkCount>1</forkCount>
          <reuseForks>true</reuseForks>
          <!-- enable-native-access=ALL-UNNAMED: required for JNI System.load in Java 25+ -->
          <argLine>--enable-native-access=ALL-UNNAMED</argLine>
        </configuration>
      </plugin>

      <!-- JAR manifest: Automatic-Module-Name for Java 9+ module system compatibility (JEP 261) -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.5.0</version>
        <configuration>
          <archive>
            <manifestEntries>
              <Automatic-Module-Name>io.decentralchain.groth16</Automatic-Module-Name>
            </manifestEntries>
          </archive>
        </configuration>
      </plugin>

      <!-- Sources JAR (required for Maven Central) -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-source-plugin</artifactId>
        <version>${maven-source-plugin.version}</version>
        <executions>
          <execution>
            <id>attach-sources</id>
            <goals><goal>jar-no-fork</goal></goals>
          </execution>
        </executions>
      </plugin>

      <!-- Javadoc JAR (required for Maven Central) -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-javadoc-plugin</artifactId>
        <version>${maven-javadoc-plugin.version}</version>
        <configuration>
          <encoding>UTF-8</encoding>
          <release>25</release>
          <!-- JNILibrary is an internal utility class with minimal Javadoc -->
          <doclint>all,-missing</doclint>
        </configuration>
        <executions>
          <execution>
            <id>attach-javadocs</id>
            <goals><goal>jar</goal></goals>
          </execution>
        </executions>
      </plugin>

      <!-- JaCoCo 0.8.14: line/branch coverage; always-on -->
      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <version>${jacoco-maven-plugin.version}</version>
        <executions>
          <execution>
            <id>jacoco-prepare-agent</id>
            <goals><goal>prepare-agent</goal></goals>
          </execution>
          <execution>
            <id>jacoco-report</id>
            <phase>verify</phase>
            <goals><goal>report</goal></goals>
          </execution>
        </executions>
      </plugin>

      <!-- CycloneDX SBOM: supply-chain transparency (CycloneDX 1.6 format) -->
      <plugin>
        <groupId>org.cyclonedx</groupId>
        <artifactId>cyclonedx-maven-plugin</artifactId>
        <version>${cyclonedx-maven-plugin.version}</version>
        <executions>
          <execution>
            <id>make-bom</id>
            <phase>package</phase>
            <goals><goal>makeBom</goal></goals>
          </execution>
        </executions>
        <configuration>
          <skipNotDeployed>false</skipNotDeployed>
          <skip>false</skip>
          <projectType>library</projectType>
          <schemaVersion>1.6</schemaVersion>
          <includeBomSerialNumber>true</includeBomSerialNumber>
          <includeCompileScope>true</includeCompileScope>
          <includeTestScope>false</includeTestScope>
          <includeRuntimeScope>true</includeRuntimeScope>
          <includeSystemScope>false</includeSystemScope>
          <includeProvidedScope>false</includeProvidedScope>
          <outputName>bom</outputName>
        </configuration>
      </plugin>

    </plugins>
  </build>

  <!-- ── Profiles ─────────────────────────────────────────────────────── -->
  <profiles>

    <!-- 'release' profile: GPG-sign + publish to Maven Central Portal -->
    <!-- Activate with: ./mvnw deploy -P release                        -->
    <profile>
      <id>release</id>
      <build>
        <plugins>

          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-gpg-plugin</artifactId>
            <version>${maven-gpg-plugin.version}</version>
            <executions>
              <execution>
                <id>sign-artifacts</id>
                <phase>verify</phase>
                <goals><goal>sign</goal></goals>
                <configuration>
                  <keyname>${gpg.keyname}</keyname>
                  <passphraseServerId>${gpg.keyname}</passphraseServerId>
                  <gpgArguments>
                    <arg>--pinentry-mode</arg>
                    <arg>loopback</arg>
                  </gpgArguments>
                </configuration>
              </execution>
            </executions>
          </plugin>

          <plugin>
            <groupId>org.sonatype.central</groupId>
            <artifactId>central-publishing-maven-plugin</artifactId>
            <version>${central-publishing-maven-plugin.version}</version>
            <extensions>true</extensions>
            <configuration>
              <publishingServerId>central</publishingServerId>
              <deploymentName>${project.artifactId}-${project.version}</deploymentName>
              <autoPublish>false</autoPublish>
            </configuration>
          </plugin>

        </plugins>
      </build>
    </profile>

    <!-- 'audit' profile: full security analysis suite.                     -->
    <!-- Activate with: ./mvnw verify -P audit                              -->
    <!--                                                                    -->
    <!-- Included tools:                                                    -->
    <!--   1. OWASP dependency-check 12.2.2  — CVE scan (NVD)              -->
    <!--      Requires NVD API key: -DnvdApiKey=$NVD_API_KEY                -->
    <!--   2. SpotBugs 4.9.8.3 + FindSecBugs 1.14.0 (OWASP)               -->
    <!--      Bytecode security analysis (JNI-specific patterns)            -->
    <!--   3. PMD 3.28.0 — source-level security + error-prone rules        -->
    <profile>
      <id>audit</id>
      <build>
        <plugins>

          <!-- OWASP dependency-check: CVE vulnerability scan against NVD -->
          <!-- Pass API key to avoid NVD rate limits:                    -->
          <!--   -DnvdApiKey=$NVD_API_KEY   (free key: nvd.nist.gov)    -->
          <!-- Skip entirely with -Ddependency-check.skip=true for local -->
          <plugin>
            <groupId>org.owasp</groupId>
            <artifactId>dependency-check-maven</artifactId>
            <version>${dependency-check-maven.version}</version>
            <configuration>
              <failBuildOnCVSS>7</failBuildOnCVSS>
              <formats>
                <format>HTML</format>
                <format>JSON</format>
              </formats>
              <skipTestScope>true</skipTestScope>
              <!-- nvdApiKey is passed via -DnvdApiKey=... on the command line;
                   falls back to unauthenticated (rate-limited) if not set    -->
              <nvdApiKey>${nvdApiKey}</nvdApiKey>
            </configuration>
            <executions>
              <execution>
                <goals><goal>check</goal></goals>
              </execution>
            </executions>
          </plugin>

          <!-- SpotBugs 4.9.8.3 + FindSecBugs 1.14.0 -->
          <plugin>
            <groupId>com.github.spotbugs</groupId>
            <artifactId>spotbugs-maven-plugin</artifactId>
            <version>${spotbugs-maven-plugin.version}</version>
            <dependencies>
              <dependency>
                <groupId>com.h3xstream.findsecbugs</groupId>
                <artifactId>findsecbugs-plugin</artifactId>
                <version>${findsecbugs-plugin.version}</version>
              </dependency>
            </dependencies>
            <configuration>
              <effort>Max</effort>
              <threshold>High</threshold>
              <includeTests>false</includeTests>
              <failOnError>true</failOnError>
              <xmlOutput>true</xmlOutput>
              <htmlOutput>true</htmlOutput>
              <!--
                Exclude JNILibrary.java from SpotBugs: it is a hawtjni utility
                class (EPL-1.0, FuseSource Corp) and uses SHA1 for non-security
                purposes (file integrity checking, not authentication/signing).
                All application-level ZK-SNARK code is fully analyzed.
              -->
              <excludeFilterFile>config/spotbugs-exclude.xml</excludeFilterFile>
            </configuration>
            <executions>
              <execution>
                <id>spotbugs-security-check</id>
                <phase>verify</phase>
                <goals><goal>check</goal></goals>
              </execution>
            </executions>
          </plugin>

          <!-- PMD 3.28.0 -->
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-pmd-plugin</artifactId>
            <version>${maven-pmd-plugin.version}</version>
            <configuration>
              <rulesets>
                <ruleset>config/pmd-ruleset.xml</ruleset>
              </rulesets>
              <targetJdk>25</targetJdk>
              <includeTests>false</includeTests>
              <failOnViolation>true</failOnViolation>
              <printFailingErrors>true</printFailingErrors>
              <!--
                JNILibrary.java is a 3rd-party utility class from the hawtjni
                project (EPL-1.0, FuseSource Corp / Eclipse Foundation).
                It predates modern Java idioms (try-with-resources, locale-aware
                string ops, proper classloader usage) by design — it must work
                on Java 6+ for maximum JNI compatibility.
                All application-level code (Groth16, ZDccJNILibrary) is fully
                analyzed without exclusions.
              -->
              <excludes>
                <exclude>**/com/decentralchain/groth16/JNILibrary.java</exclude>
              </excludes>
            </configuration>
            <executions>
              <execution>
                <id>pmd-security-check</id>
                <phase>verify</phase>
                <goals><goal>check</goal></goals>
              </execution>
            </executions>
          </plugin>

        </plugins>
      </build>
    </profile>

  </profiles>

</project>
