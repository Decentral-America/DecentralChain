<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <!-- ── Coordinates ──────────────────────────────────────────────────── -->
  <groupId>io.decentralchain</groupId>
  <artifactId>transactions-java</artifactId>
  <version>1.0.0</version>
  <packaging>jar</packaging>

  <!-- ── Project metadata (required for Maven Central) ───────────────── -->
  <name>transactions-java</name>
  <description>
    Binary and JSON serialization library for all Waves / DecentralChain
    transaction types (transfers, exchanges, invocations, Ethereum-compatible
    transactions, and more). Provides protobuf + JSON codec, Ethereum ABI
    encoding, and full builder/factory API for constructing signed transactions.
    Forked from wavesplatform/waves-transactions-java with full upstream history.
  </description>
  <url>https://github.com/Decentral-America/DCC</url>
  <inceptionYear>2021</inceptionYear>

  <licenses>
    <!-- MIT — inherited from upstream wavesplatform/waves-transactions-java -->
    <license>
      <name>MIT License</name>
      <url>https://opensource.org/licenses/MIT</url>
      <distribution>repo</distribution>
    </license>
  </licenses>

  <organization>
    <name>Decentral America</name>
    <url>https://decentralchain.io</url>
  </organization>

  <developers>
    <developer>
      <id>josue</id>
      <name>Josué</name>
      <organization>Decentral America</organization>
      <organizationUrl>https://decentralchain.io</organizationUrl>
    </developer>
  </developers>

  <scm>
    <connection>scm:git:https://github.com/Decentral-America/DCC.git</connection>
    <developerConnection>scm:git:ssh://git@github.com/Decentral-America/DCC.git</developerConnection>
    <url>https://github.com/Decentral-America/DCC/tree/main/packages/jvm/transactions-java</url>
    <tag>HEAD</tag>
  </scm>

  <issueManagement>
    <system>Jira</system>
    <url>https://decentralchain.atlassian.net</url>
  </issueManagement>

  <!-- ── Global properties ────────────────────────────────────────────── -->
  <properties>
    <!-- Java 25 — matches DecentralChain JVM ecosystem standard -->
    <maven.compiler.release>25</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

    <!-- Dependency version properties — pinned and audited 2026-05 -->
    <!-- waves-crypto 2.0.7 — latest (Feb 11, 2026); upstream unchanged -->
    <waves-crypto.version>2.0.7</waves-crypto.version>
    <!-- protobuf-schemas 1.6.0 — latest on Maven Central; upstream unchanged -->
    <protobuf-schemas.version>1.6.0</protobuf-schemas.version>
    <!-- jackson-databind 2.21.3 — latest (Apr 28, 2026); upgraded from 2.16.1 -->
    <jackson-databind.version>2.21.3</jackson-databind.version>
    <!-- web3j:crypto 5.0.2 — latest (Jan 21, 2026); MAJOR upgrade from 4.9.8.
         TransactionEncoder.encode(RawTransaction,SignatureData) is now PUBLIC
         in 5.0.x — reflection hack in EthereumTransaction.java removed. -->
    <web3j-crypto.version>5.0.2</web3j-crypto.version>
    <!-- junit-jupiter 5.14.4 — latest; upgraded from 5.8.1 -->
    <junit.version>5.14.4</junit.version>
    <!-- assertj-core 3.27.7 — latest per upstream; unchanged -->
    <assertj.version>3.27.7</assertj.version>

    <!-- Plugin versions — pinned and audited 2026-05 -->
    <!-- maven-enforcer-plugin 3.6.2 — same as upstream (released 2025) -->
    <maven-enforcer-plugin.version>3.6.2</maven-enforcer-plugin.version>
    <!-- maven-compiler-plugin 3.15.0 — latest stable (Feb 01, 2026);
         upgraded from upstream 3.14.1 -->
    <maven-compiler-plugin.version>3.15.0</maven-compiler-plugin.version>
    <!-- maven-surefire-plugin 3.5.5 — latest; upgraded from upstream's 3.5.4 -->
    <maven-surefire-plugin.version>3.5.5</maven-surefire-plugin.version>
    <!-- maven-source-plugin 3.3.1 — same as upstream -->
    <maven-source-plugin.version>3.3.1</maven-source-plugin.version>
    <!-- maven-javadoc-plugin 3.12.0 — same as upstream -->
    <maven-javadoc-plugin.version>3.12.0</maven-javadoc-plugin.version>
    <!-- maven-jar-plugin 3.5.0 — same as upstream (Nov 15, 2025) -->
    <maven-jar-plugin.version>3.5.0</maven-jar-plugin.version>
    <!-- maven-gpg-plugin 3.2.8 — same as upstream -->
    <maven-gpg-plugin.version>3.2.8</maven-gpg-plugin.version>
    <!-- central-publishing-maven-plugin 0.10.0 — latest (Jan 07, 2026);
         upgraded from upstream 0.9.0 -->
    <central-publishing-maven-plugin.version>0.10.0</central-publishing-maven-plugin.version>
    <!-- dependency-check-maven 12.2.2 — same as curve25519-java standard -->
    <dependency-check-maven.version>12.2.2</dependency-check-maven.version>
  </properties>

  <!-- ── Runtime + test dependencies ─────────────────────────────────── -->
  <dependencies>

    <!-- Waves crypto primitives (Curve25519, key derivation, hashing) -->
    <dependency>
      <groupId>com.wavesplatform</groupId>
      <artifactId>waves-crypto</artifactId>
      <version>${waves-crypto.version}</version>
    </dependency>

    <!-- Waves / DecentralChain protobuf schema definitions -->
    <dependency>
      <groupId>com.wavesplatform</groupId>
      <artifactId>protobuf-schemas</artifactId>
      <version>${protobuf-schemas.version}</version>
    </dependency>

    <!-- JSON serialization -->
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-databind</artifactId>
      <version>${jackson-databind.version}</version>
    </dependency>

    <!-- Ethereum-compatible transaction encoding (ABI, RLP, ECDSA secp256k1) -->
    <!-- bcprov-jdk15on excluded: waves-crypto ships its own Bouncy Castle  -->
    <dependency>
      <groupId>org.web3j</groupId>
      <artifactId>crypto</artifactId>
      <version>${web3j-crypto.version}</version>
      <exclusions>
        <exclusion>
          <groupId>org.bouncycastle</groupId>
          <artifactId>bcprov-jdk15on</artifactId>
        </exclusion>
        <!-- web3j 5.x may pull bcprov-jdk18on; exclude both to avoid conflicts -->
        <exclusion>
          <groupId>org.bouncycastle</groupId>
          <artifactId>bcprov-jdk18on</artifactId>
        </exclusion>
      </exclusions>
    </dependency>

    <!-- JUnit Jupiter (API + Engine + Params) — test only -->
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>

    <!-- AssertJ — fluent test assertions -->
    <dependency>
      <groupId>org.assertj</groupId>
      <artifactId>assertj-core</artifactId>
      <version>${assertj.version}</version>
      <scope>test</scope>
    </dependency>

  </dependencies>

  <!-- ── Build plugins ────────────────────────────────────────────────── -->
  <build>
    <plugins>

      <!-- Enforcer: gate Java + Maven minimums before any compilation -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
        <version>${maven-enforcer-plugin.version}</version>
        <executions>
          <execution>
            <id>enforce-minimums</id>
            <goals><goal>enforce</goal></goals>
            <configuration>
              <rules>
                <requireJavaVersion>
                  <version>[25,)</version>
                  <message>Java 25 or later is required.</message>
                </requireJavaVersion>
                <requireMavenVersion>
                  <version>[3.9,)</version>
                  <message>Maven 3.9 or later is required.</message>
                </requireMavenVersion>
              </rules>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <!-- Compiler: release 25, UTF-8 -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>${maven-compiler-plugin.version}</version>
        <configuration>
          <release>25</release>
          <encoding>UTF-8</encoding>
        </configuration>
      </plugin>

      <!-- Surefire 3.5.5: JUnit Platform auto-detected, no extra config -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>${maven-surefire-plugin.version}</version>
      </plugin>

      <!-- JAR manifest: implementation entries for version tracking -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>${maven-jar-plugin.version}</version>
        <configuration>
          <archive>
            <manifest>
              <addDefaultImplementationEntries>true</addDefaultImplementationEntries>
              <addDefaultSpecificationEntries>true</addDefaultSpecificationEntries>
            </manifest>
            <manifestEntries>
              <Specification-Title>${project.name}</Specification-Title>
              <Specification-Version>${project.version}</Specification-Version>
              <Implementation-Title>${project.groupId}.${project.artifactId}</Implementation-Title>
              <Implementation-Build-Time>${maven.build.timestamp}</Implementation-Build-Time>
            </manifestEntries>
          </archive>
        </configuration>
      </plugin>

      <!-- Sources JAR (required for Maven Central) -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-source-plugin</artifactId>
        <version>${maven-source-plugin.version}</version>
        <executions>
          <execution>
            <id>attach-sources</id>
            <goals><goal>jar-no-fork</goal></goals>
          </execution>
        </executions>
      </plugin>

      <!-- Javadoc JAR (required for Maven Central) -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-javadoc-plugin</artifactId>
        <version>${maven-javadoc-plugin.version}</version>
        <configuration>
          <encoding>UTF-8</encoding>
          <release>25</release>
          <!-- Upstream code has sparse Javadoc; suppress missing warnings -->
          <doclint>all,-missing</doclint>
        </configuration>
        <executions>
          <execution>
            <id>attach-javadocs</id>
            <goals><goal>jar</goal></goals>
          </execution>
        </executions>
      </plugin>

    </plugins>
  </build>

  <!-- ── Profiles ─────────────────────────────────────────────────────── -->
  <profiles>

    <!-- 'release' profile: GPG-sign + publish to Maven Central Portal -->
    <!-- Activate with: ./mvnw deploy -P release                        -->
    <profile>
      <id>release</id>
      <build>
        <plugins>

          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-gpg-plugin</artifactId>
            <version>${maven-gpg-plugin.version}</version>
            <executions>
              <execution>
                <id>sign-artifacts</id>
                <phase>verify</phase>
                <goals><goal>sign</goal></goals>
                <configuration>
                  <!-- GPG key ID set via CI secret: GPG_KEY_ID -->
                  <keyname>${gpg.keyname}</keyname>
                  <passphraseServerId>${gpg.keyname}</passphraseServerId>
                  <!-- Use loopback pinentry in CI (non-interactive) -->
                  <gpgArguments>
                    <arg>--pinentry-mode</arg>
                    <arg>loopback</arg>
                  </gpgArguments>
                </configuration>
              </execution>
            </executions>
          </plugin>

          <plugin>
            <groupId>org.sonatype.central</groupId>
            <artifactId>central-publishing-maven-plugin</artifactId>
            <version>${central-publishing-maven-plugin.version}</version>
            <extensions>true</extensions>
            <configuration>
              <publishingServerId>central</publishingServerId>
              <autoPublish>false</autoPublish>
            </configuration>
          </plugin>

        </plugins>
      </build>
    </profile>

    <!-- 'audit' profile: OWASP dependency-check (CVE scan against NVD).   -->
    <!-- Activate with: ./mvnw verify -P audit                              -->
    <!-- Requires NVD API key for full scan speed:                          -->
    <!--   -DnvdApiKey=$NVD_API_KEY  (or set env var NVD_API_KEY)           -->
    <!-- Without a key the scan still works but rate-limits to ~1 req/6 s.  -->
    <profile>
      <id>audit</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.owasp</groupId>
            <artifactId>dependency-check-maven</artifactId>
            <version>${dependency-check-maven.version}</version>
            <configuration>
              <!-- Fail build on CVSS score ≥ 7 (HIGH or CRITICAL) -->
              <failBuildOnCVSS>7</failBuildOnCVSS>
              <formats>
                <format>HTML</format>
                <format>JSON</format>
              </formats>
              <!-- Scan compile + runtime scope; skip test-only artifacts -->
              <skipTestScope>true</skipTestScope>
            </configuration>
            <executions>
              <execution>
                <goals><goal>check</goal></goals>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>

  </profiles>

</project>
