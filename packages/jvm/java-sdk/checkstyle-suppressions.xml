<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<!--
  Checkstyle suppressions for upstream debt inherited from the DCC SDK fork.

  These are NOT permanent exemptions — each category has a tracking issue:

  NeedBracesCheck (135 violations):
    Upstream DCC SDK code uses single-statement if/for/while without braces
    throughout. Adding braces is a safe-but-voluminous change tracked as
    technical debt. Address in a dedicated formatting PR.

  MissingJavadocType / MissingJavadocMethod (156 violations):
    The DCC SDK codebase had no Javadoc on public types or methods. Writing
    meaningful Javadoc is a documentation sprint, not a formatting pass.

  NeedBracesCheck / naming checks for domain-specific identifiers:
    - InvokeAction: field/param/method named "dApp" (decentralised application
      address) — domain term that pre-dates this codebase; renaming is a
      breaking API change.
    - Node.java: generic type parameter "TI" (TransactionInfo) — upstream
      convention; renaming to a conforming name would break callers using
      explicit type witnesses.
-->
<suppressions>

  <!-- Upstream brace style: single-statement blocks without {} -->
  <suppress checks="NeedBracesCheck" files=".*\.java"/>

  <!-- Upstream wildcard imports in production code; expanding
       requires the javaparser symbol-solver dependency (network). Tracked debt. -->
  <suppress checks="AvoidStarImportCheck" files=".*\.java"/>

  <!-- Upstream Javadoc coverage: no Javadoc on public types/methods -->
  <suppress checks="MissingJavadocTypeCheck" files=".*\.java"/>
  <suppress checks="MissingJavadocMethodCheck" files=".*\.java"/>

  <!-- Domain-specific name "dApp" (decentralised app) in InvokeAction -->
  <suppress checks="MemberNameCheck"    files="InvokeAction\.java"/>
  <suppress checks="ParameterNameCheck" files="InvokeAction\.java"/>
  <suppress checks="MethodNameCheck"    files="InvokeAction\.java"/>

  <!-- Upstream generic type "TI" (TransactionInfo) in Node.waitForTransaction -->
  <suppress checks="MethodTypeParameterNameCheck" files="Node\.java"/>

</suppressions>
