<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusion filter for packages/jvm/java-sdk.

  This file excludes known false positives from the upstream DCC SDK
  that are not genuine security issues in the DCC context.
  All entries are documented with the reason for exclusion.
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                        https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

  <!--
    EI_EXPOSE_REP / EI_EXPOSE_REP2: Mutable byte[] returns and assignments in
    blockchain data objects. The DCC SDK uses byte arrays directly for
    on-chain binary data (e.g., script bytes, proof bytes). Defensive copying
    all byte arrays in a high-throughput SDK would degrade performance without
    meaningful security benefit, as callers own the lifecycle of these objects.
  -->
  <Match>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    <Package name="com.decentralchain.sdk"/>
  </Match>
  <Match>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    <Package name="com.decentralchain.sdk.actions"/>
  </Match>
  <Match>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    <Package name="com.decentralchain.sdk.info"/>
  </Match>

  <!--
    SE_BAD_FIELD: Blockchain model classes contain non-serializable fields
    (e.g., Amount, Address) and are intentionally not Java-serializable.
    The library uses JSON (Jackson) for serialization, not Java serialization.
  -->
  <Match>
    <Bug pattern="SE_BAD_FIELD"/>
    <Package name="com.decentralchain.sdk"/>
  </Match>

  <!--
    NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE: Jackson @JsonCreator factory methods
    are guaranteed by the Node API contract to return non-null fields.
    SpotBugs cannot prove this statically but null responses are protocol errors.
  -->
  <Match>
    <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    <Class name="com.decentralchain.sdk.Node"/>
  </Match>

  <!--
    DMI_RANDOM_USED_ONLY_ONCE / PREDICTABLE_RANDOM: Ethereum transaction
    signing in DccEthConverter uses the web3j crypto library which manages
    its own secure PRNG internally. The SpotBugs heuristic fires on the
    wrapper call, not on an insecure Random instance.
  -->
  <Match>
    <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE,PREDICTABLE_RANDOM"/>
    <Class name="com.decentralchain.sdk.util.DccEthConverter"/>
  </Match>

</FindBugsFilter>
