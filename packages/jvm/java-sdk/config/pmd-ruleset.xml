<?xml version="1.0"?>
<ruleset name="DCC Java SDK Rules"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/schema/ruleset_2_0_0.xsd">

    <description>
        Custom PMD ruleset for java-sdk — DCC Java SDK (fork of Decentral-America/java-sdk).
        Categories: security (all), errorprone, bestpractices, design, performance.
        Excludes rules that conflict with intentional patterns from the upstream SDK.
    </description>

    <!-- ── Security: no exclusions ──────────────────────────────────────── -->
    <rule ref="category/java/security.xml"/>

    <!-- ── Error-prone (category/java/errorprone.xml) ───────────────────── -->
    <rule ref="category/java/errorprone.xml">
        <!--
          DCC fluent API convention: field name matches getter method name.
          e.g. private final Amount amount; public Amount amount() { ... }
          Intentional throughout the entire SDK for ergonomic API design.
        -->
        <exclude name="AvoidFieldNameMatchingMethodName"/>

        <!--
          Field name matching the type name (e.g. Balance balance in class Foo).
          Intentional DCC SDK naming convention for DTO field access.
        -->
        <exclude name="AvoidFieldNameMatchingTypeName"/>

        <!--
          Blockchain protocol constants appear multiple times across the SDK.
          Extraction to named constants would reduce readability in this domain.
        -->
        <exclude name="AvoidDuplicateLiterals"/>

        <!--
          Protocol hex and numeric literals in conditions are intentional.
          e.g. EVM type-byte checks: if (type == 0x01)
        -->
        <exclude name="AvoidLiteralsInIfCondition"/>

        <!--
          DccModule: addDeserializer/addSerializer in constructor is the
          standard Jackson SimpleModule registration pattern.
        -->
        <exclude name="ConstructorCallsOverridableMethod"/>

        <!--
          Type-safe equals methods (e.g. equals(Address other)) are intentional
          SDK convention. Object.equals is separately fulfilled via @Override.
        -->
        <exclude name="SuspiciousEqualsMethodName"/>

        <!--
          Builder patterns initialize optional fields to null explicitly to
          distinguish "not set" from "set to empty/default".
        -->
        <exclude name="NullAssignment"/>

        <!--
          Blockchain data objects are not Java-serializable by design.
          This library uses Jackson JSON for serialization.
        -->
        <exclude name="MissingSerialVersionUID"/>

        <!--
          Used intentionally in HTTP response reading loops:
          while ((n = is.read(buf)) != -1)
        -->
        <exclude name="AssignmentInOperand"/>

        <!--
          JDK HttpClient close() failures are intentionally swallowed —
          the request already completed (or failed) at that point.
        -->
        <exclude name="EmptyCatchBlock"/>

        <!--
          Node.java restores the interrupt flag via instanceof check inside
          an IOException catch block. Standard pattern without a separate
          catch clause per type.
        -->
        <exclude name="AvoidInstanceofChecksInCatchClause"/>

        <!--
          Classes instantiated via Jackson @JsonCreator have private constructors
          by design. A static factory method would conflict with Jackson's
          @JsonCreator mechanism.
        -->
        <exclude name="MissingStaticMethodInNonInstantiatableClass"/>
    </rule>

    <!-- ── Best practices (category/java/bestpractices.xml) ─────────────── -->
    <rule ref="category/java/bestpractices.xml">
        <!--
          Abstract base classes without abstract methods are used as
          template/mixin classes. Intentional inheritance pattern from upstream.
        -->
        <exclude name="AbstractClassWithoutAbstractMethod"/>

        <!--
          Concrete return types in some public API methods for explicit clarity.
        -->
        <exclude name="LooseCoupling"/>

        <!--
          Single-method interfaces are domain contracts (e.g. Recipient) that
          do not benefit from @FunctionalInterface.
        -->
        <exclude name="ImplicitFunctionalInterface"/>

        <!--
          JUnit 5 test classes use package-private access intentionally.
        -->
        <exclude name="JUnit5TestShouldBePackagePrivate"/>

        <!--
          TransactionInfo subclasses all override tx() from a base class but
          the upstream library omits @Override. Style issue from upstream code.
        -->
        <exclude name="MissingOverride"/>

        <!--
          Node.java wait/retry loop: 'spentMillis' is reassigned on each
          iteration to track elapsed time. Intentional loop design.
        -->
        <exclude name="AvoidReassigningLoopVariables"/>

        <!--
          NodeRequest inner class uses StringBuilder as a field to accumulate
          HTTP request body parts. Single-threaded request builder — not a
          thread-safety concern, not a memory leak.
        -->
        <exclude name="AvoidStringBufferField"/>
    </rule>

    <!-- ── Design (category/java/design.xml) ────────────────────────────── -->
    <rule ref="category/java/design.xml">
        <!--
          Node.java is the full DCC Node REST API client — it intentionally has
          many methods (one per endpoint). Cannot be reduced without removing
          API surface.
        -->
        <exclude name="ExcessivePublicCount"/>
        <exclude name="TooManyMethods"/>
        <exclude name="GodClass"/>
        <exclude name="ExcessiveImports"/>

        <!--
          @JsonCreator constructors in blockchain data objects have many fields
          because blockchain blocks/transactions have many metadata fields.
          Cannot be reduced without changing the on-chain data model.
        -->
        <exclude name="ExcessiveParameterList"/>

        <!--
          JSON deserializers (TransactionInfoDeser, FunctionDeser) implement
          exhaustive protocol dispatch over 30+ transaction types. Complexity
          metrics are inherent in switch-over-type-tag patterns.
        -->
        <exclude name="CyclomaticComplexity"/>
        <exclude name="NPathComplexity"/>
        <exclude name="CognitiveComplexity"/>
        <exclude name="NcssCount"/>

        <!--
          Blockchain DTOs are pure data containers by design — the DTO pattern
          is correct for SDKs wrapping external node APIs.
        -->
        <exclude name="DataClass"/>

        <!--
          TypeRef.java is a Jackson type registry — high coupling between
          objects is inherent in a centralized type registry.
        -->
        <exclude name="CouplingBetweenObjects"/>

        <!--
          Node.java has instance-level final fields set from constructor args
          that cannot be static. FinalFieldCouldBeStatic false-positive.
        -->
        <exclude name="FinalFieldCouldBeStatic"/>

        <!--
          Node.java catches Exception as the outermost handler to ensure all
          network/IO errors are translated to IOException at the boundary.
        -->
        <exclude name="AvoidCatchingGenericException"/>

        <!--
          Utility classes (CompilationUtil, DccEthConverter, HashUtil) and
          @JsonCreator classes (BlockchainRewards, Votes) have only private
          constructors. The utility classes have been made final (see source).
          @JsonCreator classes cannot be final due to Jackson reflection.
        -->
        <exclude name="ClassWithOnlyPrivateConstructorsShouldBeFinal"/>
    </rule>

    <!-- ── Multithreading (category/java/multithreading.xml) ────────────── -->
    <rule ref="category/java/multithreading.xml">
        <!--
          Node.java uses JDK virtual threads and CompletableFuture for its
          async wait/poll implementation (à la waitForTransaction). The DCC
          Node is not a J2EE application — it's a standalone blockchain SDK;
          the J2EE threading constraint does not apply here.
        -->
        <exclude name="DoNotUseThreads"/>
    </rule>

</ruleset>



