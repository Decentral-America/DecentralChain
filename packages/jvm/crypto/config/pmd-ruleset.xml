<?xml version="1.0"?>
<ruleset name="DCC crypto Rules"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/schema/ruleset_2_0_0.xsd">

    <description>
        Custom PMD ruleset for io.decentralchain:crypto.
        Pure Java cryptographic primitives:
          - Hash.java — Blake2b256 / Keccak256 / SHA256 via BouncyCastle
          - Crypto.java — Curve25519 key generation / signing
          - BlsUtils.java — BLS12-381 operations via blst
          - MerkleTree.java — Merkle root construction
          - Bytes.java — byte array utilities
          - base/Base16/58/64.java — encoding / decoding
          - rsa/RsaKeyPair/PublicKey.java — RSA sign / verify
          - internal/Dictionary.java — BIP-39 word list

        Patterns intentionally excluded:
          - Crypto methods take byte[] with fixed sizes (crypto wire format).
            UseVarargs would be semantically incorrect.
          - Abstract utility classes are not designed for serialization.
    </description>

    <!-- ALL security rules: no exclusions — crypto library must be airtight -->
    <rule ref="category/java/security.xml"/>

    <!-- Error-prone rules -->
    <rule ref="category/java/errorprone.xml">
        <!-- Utility classes are not serializable by design -->
        <exclude name="MissingSerialVersionUID"/>
        <!--
          AssignmentInOperand and AvoidLiteralsInIfCondition are idiomatic in
          Base58/Base16 encoding algorithms derived from upstream implementations.
          AvoidFieldNameMatchingMethodName: Hash.SHA256, RsaKeyPair fields follow
          the established API naming convention of this library.
          OneDeclarationPerLine: existing style in MerkleTree — cosmetic only.
        -->
        <exclude name="AssignmentInOperand"/>
        <exclude name="AvoidLiteralsInIfCondition"/>
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <exclude name="OneDeclarationPerLine"/>
    </rule>

    <!-- Best practices -->
    <rule ref="category/java/bestpractices.xml">
        <!--
          All crypto methods take byte[] with fixed sizes (key length, hash
          output, block size). Varargs would be semantically incorrect for
          fixed-size cryptographic data structures.
        -->
        <exclude name="UseVarargs"/>
        <!--
          Base58/Base16/Base64 are derived from well-known upstream implementations
          (Bitcoin/Waves). Reassigning loop variables and parameters is idiomatic
          in these algorithms and changing them would risk introducing bugs in
          security-critical encoding code.
        -->
        <exclude name="AvoidReassigningLoopVariables"/>
        <exclude name="AvoidReassigningParameters"/>
    </rule>

</ruleset>
