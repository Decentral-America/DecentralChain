<?xml version="1.0"?>
<ruleset name="DCC blst-java Rules"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/schema/ruleset_2_0_0.xsd">

    <description>
        Custom PMD ruleset for blst-java.
        This module contains SWIG-generated JNI glue code (blstJNI.java, BLST_ERROR.java)
        alongside SWIG-generated wrapper classes for BLS12-381 operations.

        SWIG-generated patterns intentionally excluded:
          - JNI long[] handle stored directly in swigCPtr (JNI memory contract)
          - BLST_ERROR enum uses static field chaining (SWIG Java enum pattern)
          - blstJNI exception wrapping without stack trace (SWIG limitation)
          - blstJNI main() uses System.out to print native resource path (debug)
    </description>

    <!-- ALL security rules: no exclusions — crypto library must be airtight -->
    <rule ref="category/java/security.xml"/>

    <!-- Error-prone rules: excluding SWIG-generated idioms -->
    <rule ref="category/java/errorprone.xml">
        <!--
          BLST_ERROR is a SWIG-generated Java enum that uses static field
          chaining: a constructor does `swigValues[swigNext++] = this`.
          This is the standard SWIG Java enum pattern for C enums — cannot be
          changed without breaking the blst_error C-enum value mapping.
        -->
        <exclude name="AssignmentInOperand"/>
        <exclude name="AssignmentToNonFinalStatic"/>

        <!--
          BLST_ERROR has both a field `swigValue` and a method `swigValue()`.
          This is a SWIG-generated naming collision; renaming either would break
          the generated JNI native method signatures.
        -->
        <exclude name="AvoidFieldNameMatchingMethodName"/>

        <!--
          blstJNI.java catches generic Exception during native library
          extraction/loading (JAR resource unpack + System.load).
          SWIG does not model Java exception chaining; the message is preserved
          but the original stack trace is lost. Known SWIG limitation.
        -->
        <exclude name="PreserveStackTrace"/>

        <!--
          JNI interop uses null as the canonical "no object" sentinel.
          getCPtr() returning null is required by JNI contract — it is passed
          as 0L (NULL pointer) to the native side.
        -->
        <exclude name="NullAssignment"/>

        <!--
          BLST_ERROR integer values correspond directly to the C enum blst_error.
          They are mathematical constants of the protocol, not magic numbers.
        -->
        <exclude name="AvoidDuplicateLiterals"/>
        <exclude name="AvoidLiteralsInIfCondition"/>

        <!--
          Blockchain model classes are not designed for Java serialization.
          BLS12-381 group elements carry native memory handles — must not serialize.
        -->
        <exclude name="MissingSerialVersionUID"/>
    </rule>

    <!-- Best practices: excluding SWIG-generated idioms -->
    <rule ref="category/java/bestpractices.xml">
        <!--
          All SWIG-generated point classes (P1, P2, Scalar, Pairing, etc.)
          store the JNI long[] handle directly in swigCPtr. This IS correct:
          long[] holds the raw pointer to the native struct. Copying would
          create a second pointer to the same memory, breaking JNI semantics.
        -->
        <exclude name="ArrayIsStoredDirectly"/>

        <!--
          blstJNI.java contains a static main() that prints the native resource
          path (JNI debug helper). Generated by SWIG's %pragma(java) jniclasscode.
        -->
        <exclude name="SystemPrintln"/>

        <!--
          SWIG generates concrete return types in the JNI wrapper dispatch chain.
        -->
        <exclude name="LooseCoupling"/>

        <!--
          SWIG-generated single-method interfaces are not @FunctionalInterface.
        -->
        <exclude name="ImplicitFunctionalInterface"/>

        <!--
          JNI glue methods take exact-size byte[] for fixed-size BLS12-381 ops.
          Varargs would be semantically wrong (48-byte G1, 96-byte G2, 32-byte scalar).
        -->
        <exclude name="UseVarargs"/>

        <!--
          SWIG-generated JNI dispatch reassigns intermediate pointers extracted
          from long[] handles — required by the JNI memory model.
        -->
        <exclude name="AvoidReassigningParameters"/>

        <!--
          SWIG generates multiple declarations per line in method bodies.
        -->
        <exclude name="OneDeclarationPerLine"/>

        <!--
          SWIG overload dispatch uses multiple loop variables simultaneously.
        -->
        <exclude name="ForLoopVariableCount"/>
    </rule>

</ruleset>
