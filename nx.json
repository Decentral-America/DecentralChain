{
  "$schema": "https://cdn.jsdelivr.net/npm/nx@22.7.4/schemas/nx-schema.json",
  "analytics": false,
  "defaultBase": "main",
  "generators": {
    "sdk-package": {
      "factory": "./tools/generators/sdk-package",
      "schema": "./tools/generators/sdk-package/schema.json"
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/test/**/*",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/vitest.config.ts"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/biome.json",
      "{workspaceRoot}/vitest.base.config.ts"
    ]
  },
  "nxCloudId": "6a07a03e8a73063a9eda9bf3",
  "plugins": [
    {
      "plugin": "./tools/nx-plugins/biome-inferred"
    },
    {
      "options": {
        "ciTargetName": "test-ci",
        "coverageTargetName": "test-coverage",
        "testTargetName": "test"
      },
      "plugin": "@nx/vitest"
    }
  ],
  "release": {
    "changelog": {
      "projectChangelogs": true,
      "workspaceChangelog": {
        "createRelease": "github",
        "file": "CHANGELOG.md"
      }
    },
    "projects": [
      "packages/sdk/*",
      "packages/ride/ts",
      "packages/ride/lang/js",
      "packages/ride/repl/js"
    ],
    "projectsRelationship": "independent",
    "version": {
      "conventionalCommits": true,
      "generatorOptions": {
        "fallbackCurrentVersionResolver": "disk"
      }
    }
  },
  "targetDefaults": {
    "biome-fix": {
      "cache": false
    },
    "biome-lint": {
      "cache": true,
      "inputs": [
        "default",
        "{workspaceRoot}/biome.json",
        {
          "externalDependencies": ["@biomejs/biome"]
        }
      ]
    },
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"]
    },
    "check:exports": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": ["production", "^production", { "externalDependencies": ["@arethetypeswrong/cli"] }]
    },
    "check:publint": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": ["production", "^production", { "externalDependencies": ["publint"] }]
    },
    "check:size": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": ["production", "^production", { "externalDependencies": ["size-limit"] }]
    },
    "nx-release-publish": {
      "dependsOn": ["build"],
      "options": {
        "packageRoot": "{projectRoot}"
      }
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^production"],
      "outputs": ["{projectRoot}/coverage", "{projectRoot}/test-results"]
    },
    "typecheck": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^production"]
    }
  }
}
